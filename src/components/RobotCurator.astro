---
---
<div id="robot-container"></div>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  let scene, camera, renderer, mixer, model, face;
  let actions = {};
  let animationId;
  let clock;

  function init() {
    const container = document.getElementById('robot-container');
    if (!container) return;
    
    // Clear previous canvas if any
    while (container.firstChild) {
        container.removeChild(container.firstChild);
    }

    scene = new THREE.Scene();
    clock = new THREE.Clock();

    // Camera setup
    camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.25, 100);
    camera.position.set(5, 2, 8); 
    camera.lookAt(0, 1, 0);

    // Lights
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
    scene.add(ambientLight);
    const dirLight = new THREE.DirectionalLight(0xEC753A, 2);
    dirLight.position.set(5, 10, 5);
    scene.add(dirLight);

    const loader = new GLTFLoader();
    loader.load('https://threejs.org/examples/models/gltf/RobotExpressive/RobotExpressive.glb', (gltf) => {
      model = gltf.scene;
      model.position.set(2, -2, 0); 
      
      model.traverse((child) => {
  if (child.isMesh) {
    child.material.wireframe = false;
    
    // Only color parts without any _number suffix (the main body parts)
    if (!child.name.match(/_\d+$/)) {
      child.material.color.setHex(0xEC753A);
    }
    // Everything with _1, _2, _3, _4 keeps original color
  }
});

      // Detect face for expressions
      model.traverse((child) => {
        if (child.isMesh && child.morphTargetDictionary && child.morphTargetInfluences) {
            face = child;
        }
      });

      scene.add(model);

      mixer = new THREE.AnimationMixer(model);
      if (gltf.animations) {
          gltf.animations.forEach((clip) => {
            const action = mixer.clipAction(clip);
            actions[clip.name] = action;
            
            // Configure non-idle animations to play once
            if (clip.name !== 'Idle' && clip.name !== 'Walking' && clip.name !== 'Running') {
                action.clampWhenFinished = true;
                action.loop = THREE.LoopOnce;
            }
          });
      }

      // Start with Wave, then go to Idle
      const startEmote = 'Wave';
      if (actions[startEmote]) {
          const action = actions[startEmote];
          action.reset().play();
          activeAction = action;
          fadeExpression('Surprised', 1, 0.2);
          
          const duration = action.getClip().duration;
          timeoutId = setTimeout(() => {
              action.fadeOut(0.2);
              fadeExpression('Surprised', 0, 0.5);
              if (actions['Idle']) actions['Idle'].reset().fadeIn(0.2).play();
              activeAction = null;
          }, duration * 1000);
      } else if (actions['Idle']) {
          actions['Idle'].play();
      }

      animate();
    }, undefined, (error) => {
        console.error('An error occurred loading the robot:', error);
    });

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    container.appendChild(renderer.domElement);
    
    container.addEventListener('click', onContainerClick);
    window.addEventListener('resize', onWindowResize, false);
  }

  function onContainerClick(event) {
  console.log('Container clicked!'); // Add this
  if (!camera || !model) return;
  
  const mouse = new THREE.Vector2();
  mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
  mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

  const raycaster = new THREE.Raycaster();
  raycaster.setFromCamera(mouse, camera);

  const intersects = raycaster.intersectObject(model, true);
  console.log('Intersects:', intersects.length); // Add this

  if (intersects.length > 0) {
    console.log('Robot hit!'); // Add this
    onRobotEmote({ detail: { name: 'Death' } });
  }
}

  function onWindowResize() {
    if (!camera || !renderer) return;
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  }

  function animate() {
    animationId = requestAnimationFrame(animate);
    if (mixer && clock) mixer.update(clock.getDelta());
    if (renderer && scene && camera) renderer.render(scene, camera);
  }

  function fadeExpression(name, targetValue, duration) {
      if (!face || !face.morphTargetDictionary) return;
      const index = face.morphTargetDictionary[name];
      if (index === undefined) return;

      const startValue = face.morphTargetInfluences[index];
      const startTime = performance.now();

      function updateExpression() {
          const elapsed = (performance.now() - startTime) / 1000;
          const t = Math.min(elapsed / duration, 1);
          
          face.morphTargetInfluences[index] = THREE.MathUtils.lerp(startValue, targetValue, t);

          if (t < 1) {
              requestAnimationFrame(updateExpression);
          }
      }
      updateExpression();
  }

  let activeAction = null;
  let timeoutId = null;

  function onRobotEmote(e) {
    const emote = e.detail.name;
    const newAction = actions[emote];
    const idleAction = actions['Idle'];

    if (newAction && newAction !== activeAction) {
        // If we have a pending return to idle, cancel it
        if (timeoutId) clearTimeout(timeoutId);

        // Fade out current active action (or idle)
        const prevAction = activeAction || idleAction;
        if (prevAction && prevAction !== newAction) {
            prevAction.fadeOut(0.2);
        }

        // Play new action
        newAction.reset();
        newAction.fadeIn(0.2);
        newAction.play();
        activeAction = newAction;

        // Expressions
        const expressionMap = {
            'Jump': 'Surprised',
            'Yes': 'Surprised',
            'No': 'Angry',
            'ThumbsUp': 'Surprised',
            'Wave': 'Surprised',
            'Death': 'Sad',
            'Punch': 'Angry'
        };
        const expression = expressionMap[emote];
        if (expression) fadeExpression(expression, 1, 0.2);

        // Schedule return to idle
        const duration = newAction.getClip().duration;
        // Add a tiny buffer to ensure it finishes
        timeoutId = setTimeout(() => {
            newAction.fadeOut(0.2);
            if (expression) fadeExpression(expression, 0, 0.5);

            if (idleAction) {
                idleAction.reset();
                idleAction.fadeIn(0.2);
                idleAction.play();
            }
            activeAction = null;
        }, duration * 1000); 
    }
  }

  // Lifecycle handling
  document.addEventListener('astro:page-load', () => {
    init();
    window.addEventListener('robot-emote', onRobotEmote);
  });

  document.addEventListener('astro:before-swap', () => {
    if (animationId) cancelAnimationFrame(animationId);
    const container = document.getElementById('robot-container');
    if (container) container.removeEventListener('click', onContainerClick);
    window.removeEventListener('resize', onWindowResize);
    window.removeEventListener('robot-emote', onRobotEmote);
    if (renderer) {
        renderer.dispose();
    }
  });
</script>

<style>
  #robot-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* Sit behind the cards (z-index: 10) but above the background */
    pointer-events: auto; /* Allow clicks on the robot */
  }
</style>
