---
export const project = {
  id: "project-4",
  type: "neovim",
  title: "nvim-plugins",
  description:
    "A collection of personal Neovim plugins. Includes <strong>onyx-colorscheme</strong> — a dark, low-contrast colorscheme built for long sessions with carefully tuned syntax highlights — and <strong>bufline.nvim</strong>, a minimal bufferline plugin with diagnostics integration.",
  links: [
    {
      label: "onyx-colorscheme",
      url: "https://github.com/kadam-x/onyx-colorscheme/tree/main",
    },
    {
      label: "bufline.nvim",
      url: "https://github.com/kadam-x/bufline.nvim",
    },
  ],
};
---

<div
  class="project-card"
  data-id={project.id}
  data-type={project.type}
>
  <div class="top-accent"></div>
  <div class="card-header">
    <span class="card-prefix">>></span>
    <h2>{project.title}</h2>
    <button
      class="info-btn-ui"
      data-info-trigger
      aria-label="Project Info"
    >
      ?
    </button>
  </div>

  <p class="project-description" set:html={project.description} />

  <div class="card-footer">
    <div class="card-links">
      {project.links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap");

  .project-card,
  .project-card[data-type="neovim"] {
    background: #0d1117;
    border: 1px solid #1e2a3a;
    font-family: "JetBrains Mono", "SF Mono", monospace;
    position: relative;
    overflow: hidden;
  }

  .project-card.hidden {
    display: none;
  }

  .top-accent {
    height: 2px;
    background: linear-gradient(90deg, #2b5b84, #569cd6, #2b5b84);
  }

  .card-header {
    display: flex;
    align-items: center;
    padding: 1rem 1.5rem 0.5rem;
    background: transparent;
    gap: 0.75rem;
    border: none;
  }

  .card-prefix {
    color: #569cd6;
    font-size: 0.75rem;
  }

  .card-header h2 {
    color: #d4d4d4;
    margin: 0;
    font-size: 1.1rem;
    font-weight: 500;
    flex-grow: 1;
    letter-spacing: -0.02em;
  }

  .info-btn-ui {
    background: transparent;
    border: 1px solid #2a3a4a;
    color: #808080;
    font-size: 0.75rem;
    cursor: pointer;
    font-family: inherit;
    padding: 0.2rem 0.5rem;
    transition: all 0.2s ease;
  }

  .info-btn-ui:hover {
    border-color: #569cd6;
    color: #569cd6;
  }

  .project-description {
    color: #a0a8b0;
    font-size: 0.8rem;
    line-height: 1.6;
    margin: 0;
    padding: 0.5rem 1.5rem 1rem;
    flex-grow: 1;
  }

  .project-description :global(strong) {
    color: #569cd6;
    font-weight: 500;
  }

  .card-footer {
    padding: 0 1.5rem 1rem;
    margin-top: auto;
  }

  .card-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .link-btn {
    color: #808080;
    text-decoration: none;
    font-size: 0.75rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid #2a3a4a;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .link-btn:hover {
    color: #569cd6;
    border-color: #569cd6;
    background: rgba(86, 156, 214, 0.06);
  }
</style>
