---
export const project = {
  id: "project-4",
  type: "neovim",
  title: "nvim-plugins",
  description:
    "A collection of personal Neovim plugins. Includes <strong>onyx-colorscheme</strong> — a dark, low-contrast colorscheme built for long sessions with carefully tuned syntax highlights — and <strong>bufline.nvim</strong>, a minimal bufferline plugin with diagnostics integration.",
  links: [
    {
      label: "onyx-colorscheme",
      url: "https://github.com/kadam-x/onyx-colorscheme/tree/main",
    },
    {
      label: "bufline.nvim",
      url: "https://github.com/kadam-x/bufline.nvim",
    },
  ],
};
---

<div
  class="project-card"
  data-id={project.id}
  data-type={project.type}
>
  <div class="left-accent"></div>
  <div class="card-body">
    <div class="logo-area">
      <img src="/logos/lua-logo.webp" alt="Lua" class="lua-logo" />
    </div>

    <p class="project-description" set:html={project.description} />

    <div class="card-footer">
      <div class="card-links">
        {project.links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="link-btn"
          >
            <span class="link-bracket">[</span>
            {link.label}
            <span class="link-bracket">]</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap");

  .project-card,
  .project-card[data-type="neovim"] {
    background: #f5f5f5;
    border: 1px solid #000080;
    font-family: "JetBrains Mono", "SF Mono", monospace;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: row;
  }

  .project-card.hidden {
    display: none;
  }

  .left-accent {
    width: 4px;
    background: #000080;
    flex-shrink: 0;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .logo-area {
    display: flex;
    align-items: center;
    padding: 0.75rem 1.25rem 0.5rem;
  }

  .lua-logo {
    width: 72px;
    height: auto;
    display: block;
  }

  .project-description {
    color: #333333;
    font-size: 0.78rem;
    line-height: 1.65;
    margin: 0;
    padding: 0.75rem 1.25rem 0.75rem;
    flex-grow: 1;
  }

  .project-description :global(strong) {
    color: #000080;
    font-weight: 500;
  }

  .card-footer {
    padding: 0.5rem 1.25rem 1rem;
    margin-top: auto;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .link-btn {
    color: #1a1a1a;
    text-decoration: none;
    font-size: 0.72rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid #000080;
    transition: all 0.15s ease;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .link-bracket {
    color: #000080;
    transition: color 0.15s ease;
  }

  .link-btn:hover {
    background: #000080;
    color: #ffffff;
  }

  .link-btn:hover .link-bracket {
    color: #ffffff;
  }

  .link-btn:active {
    transform: translateY(1px);
  }
</style>
