---
import Layout from '../layouts/Layout.astro';
import RobotCurator from '../components/RobotCurator.astro';
---

<Layout title="Projects" backgroundColor="#412E20">
  <RobotCurator />

  <main class="projects-container">
    <div class="nav-buttons" id="navButtons">
      <a href="/" class="back-link" id="homeLink">
        <span class="arrow">←</span>
        <span>take me home</span>
      </a>
      
      <button class="projects-toggle" id="projectsToggle">
        <span class="button-text">projects</span>
      </button>
    </div>
    
    <div class="projects-sidebar" id="projectsSidebar">
      <div class="projects-grid" id="projectsGrid">
        <a href="/projects/project-1" class="project-card col-1" data-emote="Yes" transition:name="project-1">
          <div class="project-header">
            <h2>Project Name</h2>
            <span class="tag">React</span>
          </div>
          <p class="project-desc">
            A brief description of what this project does and the problem it solves.
          </p>
          <div class="expand-btn-ui">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </div>
        </a>

        <a href="/projects/project-2" class="project-card col-2" data-emote="ThumbsUp" transition:name="project-2">
          <div class="project-header">
            <h2>Another Project</h2>
            <span class="tag">TypeScript</span>
          </div>
          <p class="project-desc">
            Another cool project description goes here.
          </p>
          <div class="expand-btn-ui">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </div>
        </a>

        <a href="/projects/project-3" class="project-card col-1" data-emote="Dance" transition:name="project-3">
          <div class="project-header">
            <h2>Third Project</h2>
            <span class="tag">Astro</span>
          </div>
          <p class="project-desc">
            Yet another project that showcases your skills.
          </p>
          <div class="expand-btn-ui">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </div>
        </a>

        <a href="/projects/project-4" class="project-card col-2" data-emote="Jump" transition:name="project-4">
          <div class="project-header">
            <h2>Fourth Project</h2>
            <span class="tag">Node.js</span>
          </div>
          <p class="project-desc">
            A backend project showcasing server-side skills.
          </p>
          <div class="expand-btn-ui">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </div>
        </a>

        </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function() {
    // Persistent state
    if (!window._projectsState) {
      window._projectsState = { isOpen: false };
    }
    
    let isProjectsOpen = window._projectsState.isOpen;

    // Helper to trigger Robot Animations
    function robotReact(emoteName) {
      window.dispatchEvent(new CustomEvent('robot-emote', { 
        detail: { name: emoteName } 
      }));
    }

    function initProjectsToggle() {
      const projectsToggle = document.getElementById('projectsToggle');
      const projectsSidebar = document.getElementById('projectsSidebar');
      const homeLink = document.getElementById('homeLink');
      
      if (projectsToggle && projectsSidebar && homeLink) {
        const newToggle = projectsToggle.cloneNode(true);
        projectsToggle.parentNode.replaceChild(newToggle, projectsToggle);
        
        const newButtonText = newToggle.querySelector('.button-text');
        
        // Initial setup based on state
        if (isProjectsOpen) {
          if (newButtonText) newButtonText.textContent = '<-back';
          homeLink.classList.add('hidden');
          projectsSidebar.classList.add('active');
        }
        
        newToggle.addEventListener('click', function() {
          if (!isProjectsOpen) {
            isProjectsOpen = true;
            window._projectsState.isOpen = true;
            if (newButtonText) newButtonText.textContent = '<-back';
            homeLink.classList.add('hidden');
            projectsSidebar.classList.remove('closing');
            projectsSidebar.classList.add('active');
            
            // Robot says hello!
            robotReact('Wave');
          } else {
            isProjectsOpen = false;
            window._projectsState.isOpen = false;
            projectsSidebar.classList.add('closing');
            if (newButtonText) newButtonText.textContent = 'projects';
            homeLink.classList.remove('hidden');
            
            // Robot takes a break
            robotReact('Idle');
            
            setTimeout(function() {
              projectsSidebar.classList.remove('active', 'closing');
            }, 400);
          }
        });
      }

      // Hook up Card Hovers to Robot
      const cards = document.querySelectorAll('.project-card');
      cards.forEach(card => {
        card.addEventListener('mouseenter', () => {
          const emote = card.getAttribute('data-emote') || 'Standing';
          robotReact(emote);
        });
      });
    }

    function init() {
      const referrer = document.referrer;
      const fromProjectDetail = referrer && referrer.includes('/projects/project-');
      const fromIndex = referrer && (new URL(referrer).pathname === '/');
      
      if (fromIndex) {
        isProjectsOpen = false;
        window._projectsState.isOpen = false;
      } else if (fromProjectDetail) {
        isProjectsOpen = window._projectsState.isOpen;
      }
      
      initProjectsToggle();
    }

    // Astro lifecycle hooks
    init();
    document.addEventListener('astro:page-load', init);
    
    document.addEventListener('click', function(e) {
      const link = e.target.closest('a');
      if (link && (new URL(link.href, location.origin).pathname === '/')) {
        window._projectsState.isOpen = false;
      }
    });
  })();
</script>

<style>
  .projects-container {
    position: relative;
    z-index: 10; /* Above robot and vanta */
    min-height: 100vh;
  }

  .nav-buttons {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Navigation Links */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #FFE4AF;
    font-size: 1rem;
    text-decoration: none;
    font-family: 'Fira Code', monospace;
    animation: slideInFromRight 0.5s ease forwards;
    animation-delay: 0.2s;
    opacity: 0;
  }

  .back-link.hidden {
    opacity: 0 !important;
    pointer-events: none;
  }

  .projects-toggle {
    color: #D73F24;
    font-size: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Fira Code', monospace;
    font-weight: 700;
    text-align: left;
    animation: slideInFromRight 0.5s ease forwards;
    animation-delay: 0.35s;
    opacity: 0;
  }

  .projects-toggle:hover { color: #EC753A; }

  /* Sidebar and Grid */
  .projects-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    padding: 4rem 2rem;
    overflow-y: auto;
    z-index: 15;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .projects-sidebar.active {
    opacity: 1;
    pointer-events: all;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 260px);
    gap: 1rem;
    padding-top: 6rem;
    padding-left: 2rem;
    width: fit-content;
  }

  /* Project Cards */
  .project-card {
    background: rgba(65, 46, 32, 0.9); /* Slight transparency to show robot behind */
    border: 3px solid #DA9F5F;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(-100vw);
    display: block;
  }

  .projects-sidebar.active .project-card {
    animation: slideInFromLeft 0.4s ease both;
  }

  .project-card:hover {
    border-color: #EC753A;
    transform: translateX(8px);
    box-shadow: 0 0 20px rgba(236, 117, 58, 0.4);
  }

  /* Expand Button UI (No longer a <button> to allow nesting) */
  .expand-btn-ui {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    width: 28px;
    height: 28px;
    border: 2px solid #DA9F5F;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px;
  }

  .expand-btn-ui svg { color: #DA9F5F; width: 100%; height: 100%; }
  .project-card:hover .expand-btn-ui { background: #EC753A; border-color: #EC753A; }
  .project-card:hover .expand-btn-ui svg { color: #342331; }

  /* Text Styles */
  .project-header h2 { font-size: 1.2rem; color: #FFE4AF; margin: 0; }
  .tag { background: #DA9F5F; color: #342331; padding: 0.1rem 0.5rem; font-size: 0.75rem; border: 1px solid #EC753A; }
  .project-desc { color: #DA9F5F; font-size: 0.85rem; line-height: 1.4; margin-top: 0.5rem; }

  /* Animations */
  @keyframes slideInFromLeft { from { transform: translateX(-100vw); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes slideInFromRight { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  .projects-sidebar.closing .project-card { animation: slideOutToLeft 0.4s ease both; }
  @keyframes slideOutToLeft { from { transform: translateX(0); opacity: 1; } to { transform: translateX(-100vw); opacity: 0; } }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; width: 100%; padding-left: 1rem; }
  }
</style>
