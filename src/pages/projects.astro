---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects" backgroundColor="#412E20">
  <div id="vanta-background" data-astro-transition-scope="vanta-bg"></div>
  <main class="projects-container">
    <div class="nav-buttons" id="navButtons">
      <a href="/" class="back-link" id="homeLink">
        <span class="arrow">←</span>
        <span>take me home</span>
      </a>
      
      <button class="projects-toggle" id="projectsToggle">
        <span class="button-text">projects</span>
      </button>
    </div>
    
    <div class="projects-sidebar" id="projectsSidebar">
      <div class="projects-grid" id="projectsGrid">
        <!-- Column 1 -->
        <a href="/projects/project-1" class="project-card col-1" transition:name="project-1">
          <div class="project-header">
            <h2>Project Name</h2>
            <span class="tag">React</span>
          </div>
          <p class="project-desc">
            A brief description of what this project does and the problem it solves.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-2" class="project-card col-2" transition:name="project-2">
          <div class="project-header">
            <h2>Another Project</h2>
            <span class="tag">TypeScript</span>
          </div>
          <p class="project-desc">
            Another cool project description goes here.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-3" class="project-card col-1" transition:name="project-3">
          <div class="project-header">
            <h2>Third Project</h2>
            <span class="tag">Astro</span>
          </div>
          <p class="project-desc">
            Yet another project that showcases your skills.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-4" class="project-card col-2" transition:name="project-4">
          <div class="project-header">
            <h2>Fourth Project</h2>
            <span class="tag">Node.js</span>
          </div>
          <p class="project-desc">
            A backend project showcasing server-side skills.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-5" class="project-card col-1" transition:name="project-5">
          <div class="project-header">
            <h2>Fifth Project</h2>
            <span class="tag">Python</span>
          </div>
          <p class="project-desc">
            A data-focused project with Python.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-6" class="project-card col-2" transition:name="project-6">
          <div class="project-header">
            <h2>Sixth Project</h2>
            <span class="tag">Vue</span>
          </div>
          <p class="project-desc">
            A Vue.js application with modern features.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-7" class="project-card col-1" transition:name="project-7">
          <div class="project-header">
            <h2>Seventh Project</h2>
            <span class="tag">Rust</span>
          </div>
          <p class="project-desc">
            A high-performance systems project.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>

        <a href="/projects/project-8" class="project-card col-2" transition:name="project-8">
          <div class="project-header">
            <h2>Eighth Project</h2>
            <span class="tag">Go</span>
          </div>
          <p class="project-desc">
            A cloud-native application built with Go.
          </p>
          <button class="expand-btn" aria-label="View project details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        </a>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function() {
    // Use window object to persist state across page navigations
    if (!window._projectsState) {
      window._projectsState = { isOpen: false };
    }
    
    let isProjectsOpen = false;

    function initProjectsToggle() {
      const projectsToggle = document.getElementById('projectsToggle');
      const projectsSidebar = document.getElementById('projectsSidebar');
      const homeLink = document.getElementById('homeLink');
      const buttonText = projectsToggle ? projectsToggle.querySelector('.button-text') : null;
      
      if (projectsToggle && projectsSidebar && homeLink && buttonText) {
        const newToggle = projectsToggle.cloneNode(true);
        const parent = projectsToggle.parentNode;
        if (parent) {
          parent.replaceChild(newToggle, projectsToggle);
        }
        
        const newButtonText = newToggle.querySelector('.button-text');
        
        // Restore sidebar state if it was open
        if (isProjectsOpen) {
          if (newButtonText) newButtonText.textContent = '<-back';
          homeLink.classList.add('hidden');
          projectsSidebar.classList.remove('closing');
          projectsSidebar.classList.add('active');
        }
        
        newToggle.addEventListener('click', function() {
          if (!isProjectsOpen) {
            isProjectsOpen = true;
            window._projectsState.isOpen = true;
            if (newButtonText) newButtonText.textContent = '<-back';
            homeLink.classList.add('hidden');
            projectsSidebar.classList.remove('closing');
            projectsSidebar.classList.add('active');
          } else {
            isProjectsOpen = false;
            window._projectsState.isOpen = false;
            projectsSidebar.classList.add('closing');
            if (newButtonText) newButtonText.textContent = 'projects';
            homeLink.classList.remove('hidden');
            
            setTimeout(function() {
              projectsSidebar.classList.remove('active', 'closing');
            }, 400);
          }
        });
      }
    }

    function init() {
      // Check if we're coming from a project detail page
      var referrer = document.referrer;
      var fromProjectDetail = referrer && referrer.includes('/projects/project-');
      
      // If coming from a project detail page, restore the state
      // Otherwise, only restore if state was explicitly set (not from index)
      if (fromProjectDetail) {
        isProjectsOpen = window._projectsState.isOpen || false;
      } else {
        // Check if we're coming from index (home page)
        var fromIndex = referrer && (referrer.endsWith('/') || referrer.endsWith('/index.html') || new URL(referrer).pathname === '/');
        if (fromIndex) {
          // Reset state when coming from index
          isProjectsOpen = false;
          window._projectsState.isOpen = false;
        } else {
          // Restore state for other cases (e.g., direct navigation)
          isProjectsOpen = window._projectsState.isOpen || false;
        }
      }
      
      initProjectsToggle();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    document.addEventListener('astro:page-load', init);
    
    // Reset state when navigating to home
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a');
      if (link && link.href) {
        try {
          var url = new URL(link.href, location.origin);
          if (url.pathname === '/' || url.pathname === '/index.html') {
            window._projectsState.isOpen = false;
          }
        } catch(err) {}
      }
    });
  })();
</script>

<style>
  #vanta-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .projects-container {
    position: relative;
    z-index: 1;
    min-height: 100vh;
  }

  @keyframes slideInFromRight {
    from {
      opacity: 0;
      transform: translateX(100px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .nav-buttons {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: opacity 0.3s ease;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #FFE4AF;
    font-size: 1rem;
    transition: opacity 0.3s, transform 0.3s;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    opacity: 0;
    transform: translateX(100px);
    animation: slideInFromRight 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    animation-delay: 0.2s;
  }

  .back-link.hidden {
    opacity: 0 !important;
    transform: translateY(-10px) !important;
    pointer-events: none;
    animation: none !important;
  }

  .back-link:hover {
    color: #EC753A;
  }

  .arrow {
    font-size: 1.5rem;
  }

  .projects-toggle {
    color: #D73F24;
    font-size: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    transition: all 0.2s;
    text-align: left;
    font-weight: 700;
    opacity: 0;
    transform: translateX(100px);
    animation: slideInFromRight 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    animation-delay: 0.35s;
  }

  .projects-toggle:hover {
    color: #EC753A;
  }

  .projects-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    padding: 4rem 2rem;
    background: transparent;
    overflow-y: auto;
    overflow-x: hidden;
    z-index: 5;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .projects-sidebar::-webkit-scrollbar {
    display: none;
  }

  .projects-sidebar.active {
    opacity: 1;
    pointer-events: all;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 260px);
    gap: 1rem;
    padding-top: 6rem;
    padding-left: 2rem;
    width: fit-content;
  }

  .project-card {
    background: #412E20;
    border: 3px solid #DA9F5F;
    padding: 1rem 1.25rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(-100vw);
    opacity: 0;
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .expand-btn {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 2px solid #DA9F5F;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    padding: 5px;
    pointer-events: none;
  }

  .expand-btn svg {
    width: 100%;
    height: 100%;
    color: #DA9F5F;
    transition: color 0.2s;
  }

  .project-card:hover .expand-btn {
    border-color: #EC753A;
    background: #EC753A;
  }

  .project-card:hover .expand-btn svg {
    color: #342331;
  }

  /* Opening animation */
  .projects-sidebar.active .project-card {
    animation: slideInFromLeft 0.4s ease both;
  }

  .projects-sidebar.active .project-card.col-1:nth-of-type(1) { animation-delay: 0.05s; }
  .projects-sidebar.active .project-card.col-1:nth-of-type(3) { animation-delay: 0.1s; }
  .projects-sidebar.active .project-card.col-1:nth-of-type(5) { animation-delay: 0.15s; }
  .projects-sidebar.active .project-card.col-1:nth-of-type(7) { animation-delay: 0.2s; }
  .projects-sidebar.active .project-card.col-2:nth-of-type(2) { animation-delay: 0.15s; }
  .projects-sidebar.active .project-card.col-2:nth-of-type(4) { animation-delay: 0.2s; }
  .projects-sidebar.active .project-card.col-2:nth-of-type(6) { animation-delay: 0.25s; }
  .projects-sidebar.active .project-card.col-2:nth-of-type(8) { animation-delay: 0.3s; }

  /* Closing animation */
  .projects-sidebar.closing .project-card {
    animation: slideOutToLeft 0.4s ease both !important;
  }

  .projects-sidebar.closing .project-card.col-2:nth-of-type(8) { animation-delay: 0.05s; }
  .projects-sidebar.closing .project-card.col-2:nth-of-type(6) { animation-delay: 0.1s; }
  .projects-sidebar.closing .project-card.col-2:nth-of-type(4) { animation-delay: 0.15s; }
  .projects-sidebar.closing .project-card.col-2:nth-of-type(2) { animation-delay: 0.2s; }
  .projects-sidebar.closing .project-card.col-1:nth-of-type(7) { animation-delay: 0.15s; }
  .projects-sidebar.closing .project-card.col-1:nth-of-type(5) { animation-delay: 0.2s; }
  .projects-sidebar.closing .project-card.col-1:nth-of-type(3) { animation-delay: 0.25s; }
  .projects-sidebar.closing .project-card.col-1:nth-of-type(1) { animation-delay: 0.3s; }

  @keyframes slideInFromLeft {
    from {
      transform: translateX(-100vw);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes slideOutToLeft {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(-100vw);
      opacity: 0;
    }
  }

  .project-card:hover {
    border-color: #EC753A;
    transform: translateX(8px);
    box-shadow: 0 12px 24px rgba(236, 117, 58, 0.3);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    gap: 1rem;
  }

  .project-header h2 {
    font-size: 1.2rem;
    color: #FFE4AF;
  }

  .tag {
    background: #DA9F5F;
    color: #342331;
    padding: 0.25rem 0.75rem;
    font-size: 0.85rem;
    border: 1px solid #EC753A;
  }

  .project-desc {
    color: #DA9F5F;
    line-height: 1.5;
    margin-bottom: 0;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      padding-top: 5rem;
      padding-left: 1rem;
      padding-right: 1rem;
      width: 100%;
    }

    .nav-buttons {
      top: 1rem;
      left: 1rem;
    }

    .project-card {
      padding: 1.25rem;
    }

    .projects-sidebar.active .project-card:nth-child(1) { animation-delay: 0.05s; }
    .projects-sidebar.active .project-card:nth-child(2) { animation-delay: 0.1s; }
    .projects-sidebar.active .project-card:nth-child(3) { animation-delay: 0.15s; }
    .projects-sidebar.active .project-card:nth-child(4) { animation-delay: 0.2s; }
    .projects-sidebar.active .project-card:nth-child(5) { animation-delay: 0.25s; }
    .projects-sidebar.active .project-card:nth-child(6) { animation-delay: 0.3s; }
    .projects-sidebar.active .project-card:nth-child(7) { animation-delay: 0.35s; }
    .projects-sidebar.active .project-card:nth-child(8) { animation-delay: 0.4s; }

    .projects-sidebar.closing .project-card:nth-child(8) { animation-delay: 0.05s; }
    .projects-sidebar.closing .project-card:nth-child(7) { animation-delay: 0.1s; }
    .projects-sidebar.closing .project-card:nth-child(6) { animation-delay: 0.15s; }
    .projects-sidebar.closing .project-card:nth-child(5) { animation-delay: 0.2s; }
    .projects-sidebar.closing .project-card:nth-child(4) { animation-delay: 0.25s; }
    .projects-sidebar.closing .project-card:nth-child(3) { animation-delay: 0.3s; }
    .projects-sidebar.closing .project-card:nth-child(2) { animation-delay: 0.35s; }
    .projects-sidebar.closing .project-card:nth-child(1) { animation-delay: 0.4s; }
  }
</style>