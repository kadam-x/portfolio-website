---
import Layout from "../layouts/Layout.astro";
import AvatarCurator from "../components/AvatarCurator.astro";
import RBLCard from "../components/cards/RBLCard.astro";
import IVSurfaceCard from "../components/cards/IVSurfaceCard.astro";
import DeadSailCard from "../components/cards/CatchWind.astro";
import NvimPluginsCard from "../components/cards/nvim-plugins.astro";
---

<Layout
  title="Kovacs Adam :: Projects"
  showProfile={false}
  useGridBackground={true}
>
  <AvatarCurator transition:persist />

  <main class="projects-container">
    <div class="top-bar">
      <a href="/" class="back-link" id="homeLink"> &lt; take me home </a>

      <div class="projects-nav">
        <button class="nav-arrow" id="prevBtn">&lt; prev</button>
        <span class="page-counter" id="pageCounter">1 / 4</span>
        <button class="nav-arrow" id="nextBtn">next &gt;</button>
      </div>
    </div>

    <div class="projects-sidebar active">
      <div class="projects-grid">
        <RBLCard />
        <IVSurfaceCard />
        <DeadSailCard />
        <NvimPluginsCard />
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function () {
    function robotReact(emoteName) {
      window.dispatchEvent(
        new CustomEvent("robot-emote", {
          detail: { name: emoteName },
        }),
      );
    }

    function initPage() {
      const homeLink = document.getElementById("homeLink");

      if (homeLink) {
        homeLink.addEventListener("mouseenter", () => robotReact("Wave"));
      }

      const EMOTES = ["Jump", "Yes", "No", "Wave", "ThumbsUp"];
      const STATES = ["Dance"];
      const EXPRESSIONS = ["talking"];
      const PROJECT_DIALOGUES = {
        "project-1":
          "I built this because prediction markets and DeFI are one of the few places where insider positioning is both legal and detectable. The real question is not whether the retail can catch up in time",
        "project-2":
          "I wanted to build something that sits closer to how risk systems actually work than a typical portfolio project. Fetching the chain, inverting Black-Scholes numerically per strike, warehousing it properly, serving it through an API. Getting Brent's method to behave at the wings was the part that kept me up.",
        "project-3":
          "Two ships. One keyboard. Zero mercy. Been wanting to build a dual-screen shooter since I played those old flash games. The core mechanic of mirrored movement but opposite firing directions creates this puzzle-like flow where you have to think about both sides simultaneously.",
        "project-4":
          "Every colorscheme I tried either burned my eyes or put me to sleep. So I made my own. Onyx is what happens when you spend too much time staring at a screen and start caring about which exact shade of muted teal doesn't give you a headache.",
      };

      const ALL_ANIMATIONS = [...EMOTES, ...STATES];

      document.querySelectorAll("[data-info-trigger]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const card = btn.closest(".project-card");
          const id = card.getAttribute("data-id");

          const randomEmote =
            ALL_ANIMATIONS[Math.floor(Math.random() * ALL_ANIMATIONS.length)];
          const randomExpression =
            EXPRESSIONS[Math.floor(Math.random() * EXPRESSIONS.length)];

          window.dispatchEvent(
            new CustomEvent("robot-emote", {
              detail: {
                name: randomEmote,
                text: PROJECT_DIALOGUES[id],
                expression: randomExpression,
              },
            }),
          );
        });
      });

      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const pageCounter = document.getElementById("pageCounter");
      const cards = document.querySelectorAll(".project-card");
      const totalPages = cards.length;
      let currentPage = 0;

      function showPage(page) {
        cards.forEach((card, index) => {
          if (index === page) {
            card.classList.remove("hidden");
          } else {
            card.classList.add("hidden");
          }
        });

        if (pageCounter) {
          pageCounter.textContent = `${page + 1} / ${totalPages}`;
        }

        prevBtn.disabled = page === 0;
        nextBtn.disabled = page === totalPages - 1;
      }

      if (prevBtn && nextBtn) {
        showPage(currentPage);

        prevBtn.addEventListener("click", () => {
          if (currentPage > 0) {
            currentPage--;
            showPage(currentPage);
          }
        });

        nextBtn.addEventListener("click", () => {
          if (currentPage < totalPages - 1) {
            currentPage++;
            showPage(currentPage);
          }
        });
      }
    }

    initPage();
    document.addEventListener("astro:page-load", initPage);
  })();
</script>

<style is:global>
  .projects-container {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    padding: 6rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .projects-sidebar {
    flex: 1;
    display: flex;
    align-items: flex-start;
    padding-top: 16vh;
    width: 100%;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    width: 100%;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    margin-left: 3rem;
  }

  .back-link:hover {
    background: #000000;
    color: #ffffff;
  }

  .projects-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-right: 6rem;
  }

  .page-counter {
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    font-size: 1rem;
    color: #000000;
    min-width: 3rem;
    text-align: center;
  }

  .nav-arrow {
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
  }

  .nav-arrow:hover {
    background: #000000;
    color: #ffffff;
  }

  .nav-arrow:disabled {
    background: #c0c0c0;
    color: #808080;
    cursor: not-allowed;
    border-color: #808080 #ffffff #ffffff #808080;
  }

  .nav-arrow:disabled:hover {
    background: #c0c0c0;
    color: #808080;
  }

  .projects-grid {
    width: 100%;
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    gap: 1rem;
    justify-content: flex-end;
    align-items: flex-end;
    padding-bottom: 1rem;
    padding-right: 6rem;
  }

  .project-card {
    border: 2px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    padding: 0;
    width: 80rem;
    max-width: 80rem;
    min-height: 360px;
    flex-shrink: 0;
    background: #c0c0c0;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    font-size: 1rem;
    display: flex;
    flex-direction: column;
  }

  .project-card.hidden {
    display: none;
  }

  /* — trading — */
  .project-card[data-type="trading"] {
    background: #c0c0c0;
  }

  /* — engineering — */
  .project-card[data-type="engineering"] {
    background: #c0c0c0;
  }

  /* — game — */
  .project-card[data-type="game"] {
    background: #1a1a2e;
    border-color: #0f0f1a #4a4a6a #4a4a6a #0f0f1a;
  }

  .project-card[data-type="game"] .card-header {
    background: #0f0f1a;
  }

  .project-card[data-type="game"] .card-header h2 {
    color: #00ff88;
  }

  .project-card[data-type="game"] .card-prefix {
    color: #00ff88;
  }

  .project-card[data-type="game"] .project-description {
    color: #e0e0e0;
  }

  /* — shared card structure — */
  .card-header {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 0.5rem 1rem;
    background: #000033;
    gap: 0.5rem;
  }

  .card-prefix {
    color: #ffffff;
    font-size: 14px;
  }

  .card-header h2 {
    font-size: 14px;
    color: #ffffff;
    margin: 0;
    font-weight: normal;
    flex-grow: 1;
  }

  .info-btn-ui {
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
    min-width: 1.5rem;
    text-align: center;
  }

  .info-btn-ui:hover {
    background: #000000;
    color: #ffffff;
  }

  .project-description {
    color: #000000;
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    padding: 1rem;
    flex-grow: 1;
  }

  .project-description .desk-name {
    font-weight: bold;
    color: #000033;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .link-btn {
    color: #0000ff;
    text-decoration: underline;
  }

  .card-footer {
    padding: 1rem;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .link-btn:hover {
    color: #ff0000;
  }

  @media (max-width: 768px) {
    .projects-grid {
      flex-wrap: nowrap;
      overflow-x: auto;
    }
    .project-card {
      width: 280px;
    }
  }
</style>
