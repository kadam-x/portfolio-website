---
import Layout from "../layouts/Layout.astro";
import AvatarCurator from "../components/AvatarCurator.astro"

const projects = [
  {
    id: "project-1",
    title: "Implied Volatility Surface Pipeline",
    description:
      "A full data engineering pipeline that ingests SPY options chain data daily, inverts Black-Scholes to compute implied volatility across all strikes and expiries, and stores results in a star-schema warehouse served via REST API and Grafana dashboard.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Docker", color: "#1d63ed" },
      { name: "FastAPI", color: "#04988a" },
      { name: "Airflow", color: "#e43921" },
      { name: "MinIO", color: "#cf163e" },
      { name: "Grafana", color: "#ff671d" },
    ],
    links: [
      {
        label: "View Code",
        url: "https://github.com/kadam-x/volatility-surface-pipeline",
      },
    ],
  },
  {
    id: "project-2",
    title: "Pricing Library Benchmark & Profiler",
    description:
      "A modular Python library implementing Black-Scholes, Monte Carlo, and binomial tree options pricing with systematic benchmarking of numerical accuracy versus computational cost across parameter regimes.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Docker", color: "#1d63ed" },
      { name: "FastAPI", color: "#04988a" },
      { name: "Airflow", color: "#e43921" },
      { name: "MinIO", color: "#cf163e" },
      { name: "Grafana", color: "#ff671d" },
    ],
    links: [
      { label: "View Code", url: "https://github.com/kadam-x/volatility-surface-pipeline" },
    ],
  },
  {
    id: "project-3",
    title: "ML Factor Signal Monitor",
    description:
      "A signal generation and monitoring pipeline for equity factor strategies. Computes momentum and mean-reversion signals, trains an XGBoost classifier with walk-forward validation, and tracks signal decay and feature importance drift over rolling windows.",
    techStack: [
      { name: "React", color: "#61DAFB" },
      { name: "Next.js", color: "#000000" },
      { name: "TypeScript", color: "#3178C6" },
      { name: "Framer", color: "#0055FF" },
    ],
    links: [
      { label: "View Code", url: "https://github.com/kadam-x/ml-factor-signal-monitor" },
    ],
  },
  {
    id: "project-4",
    title: "Urban Mobility Anomaly Detection",
    description:
      "Unsupervised anomaly detection on Citibike NYC trip data. Isolation Forest flags unusual demand patterns per station per time window, DBSCAN clusters stations by behaviour, and SHAP explains what drove each anomaly score.",
    techStack: [
      { name: "React", color: "#61DAFB" },
      { name: "Next.js", color: "#000000" },
      { name: "TypeScript", color: "#3178C6" },
      { name: "Framer", color: "#0055FF" },
    ],
    links: [
      { label: "View Code", url: "https://github.com/kadam-x/urban-mob-anom-det" },
    ],
  },
  {
    id: "project-5",
    title: "Sports Performance Analytics",
    description:
      "A Bloomberg style crypto arbitrage bot using CoinGecko's API, Binance's API calculates spread and visualizes 24H data.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "API", color: "#F7B731" },
    ],
    links: [
      { label: "View Code", url: "https://github.com/kadam-x/sports-perf-analytics" },
    ],
  },
  {
    id: "project-8",
    title: "CopyBot",
    description:
      "A Python-based system for monitoring, analyzing, and optimizing Solana copy-trading wallets using real-time on-chain data and post-trade performance tracking. It ingests real-time wallet activity via webhooks, enriches trades with market and risk data, and tracks post-purchase token performance using delayed OHLCV analysis.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Solana", color: "#9945FF" },
      { name: "Webhooks", color: "#a1cd5e" },
      { name: "Async", color: "#a1cd5e" },
    ],
    links: [
      {
        label: "View Code",
        url: "https://github.com/snezzz0/solana-wallet-tracker-old/",
      },
    ],
  },
  {
    id: "project-7",
    title: "Siege X Guide",
    description:
      "Interactive Rainbow Six Siege tactical guide featuring comprehensive map callouts, operator strategies, and gameplay tips for competitive players. Built with Next.js 15 featuring smooth animations with Framer Motion.",
    techStack: [
      { name: "React", color: "#61DAFB" },
      { name: "Next.js", color: "#000000" },
      { name: "TypeScript", color: "#3178C6" },
      { name: "Framer", color: "#0055FF" },
    ],
    links: [
      { label: "Live Demo", url: "https://siege-x-guide.vercel.app/" },
      { label: "View Code", url: "https://github.com/snezzz0/siegex" },
    ],
  },
  {
    id: "project-8",
    title: "CopyBot",
    description:
      "A Python-based system for monitoring, analyzing, and optimizing Solana copy-trading wallets using real-time on-chain data and post-trade performance tracking. It ingests real-time wallet activity via webhooks, enriches trades with market and risk data, and tracks post-purchase token performance using delayed OHLCV analysis.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Solana", color: "#9945FF" },
      { name: "Webhooks", color: "#a1cd5e" },
      { name: "Async", color: "#a1cd5e" },
    ],
    links: [
      {
        label: "View Code",
        url: "https://github.com/snezzz0/solana-wallet-tracker-old/",
      },
    ],
  },
  ];
---

<Layout title="Kovacs Adam :: Projects" backgroundColor="#030210">
  <AvatarCurator transition:persist />

  <main class="projects-container">
    <a href="/" class="back-link" id="homeLink">
      &lt; take me home
    </a>

    <div class="projects-nav">
      <button class="nav-arrow" id="prevBtn">&lt; prev</button>
      <span class="nav-indicator" id="navIndicator">1-3</span>
      <button class="nav-arrow" id="nextBtn">next &gt;</button>
    </div>

    <div class="projects-sidebar active">
      <div class="projects-grid">
        {
          projects.map((project, index) => (
            <div class="project-card" data-id={project.id} data-index={index}>
              <div class="card-header">
                <span class="card-prefix">[*]</span>
                <h2>{project.title}</h2>
                <button
                  class="info-btn-ui"
                  data-info-trigger
                  aria-label="Project Info"
                >
                  ?
                </button>
              </div>

              {!project.isLearning && (
                <div class="video-placeholder">
                  <span>Live Demo</span>
                </div>
              )}

              <p class="project-description">{project.description}</p>

              <div class="card-footer">
                <div class="tech-stack">
                  {project.techStack.map((tech) => (
                    <span
                      class="tech-tag"
                      style={`background-color: ${tech.color}20; border-color: ${tech.color}40; color: ${tech.color};`}
                    >
                      {tech.name}
                    </span>
                  ))}
                </div>

                <div class="card-links">
                  {project.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="link-btn"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function () {
    function robotReact(emoteName) {
      window.dispatchEvent(
        new CustomEvent("robot-emote", {
          detail: { name: emoteName },
        }),
      );
    }

    function initPage() {
      const homeLink = document.getElementById("homeLink");

      if (homeLink) {
        homeLink.addEventListener("mouseenter", () => robotReact("Wave"));
      }

      const EMOTES = ["Jump", "Yes", "No", "Wave", "ThumbsUp"];
      const STATES = ["Dance"];
      const EXPRESSIONS = ["talking"];
      const PROJECT_DIALOGUES = {
        "project-1":
          "I wanted to build something that quant desks actually use not a backtest, but the infrastructure underneath. This computes the vol surface the same way a risk system would: fetch the chain, invert BS numerically per strike, load it into a proper warehouse, serve it via API. The Brent's method inversion was the most interesting part to get right.",
        "project-2": "I was curious about, when does Monte Carlo beat the binomial tree, and when does it not? I implemented all three methods behind a unified interface, then swept across moneyness, time to expiry, and volatility regimes to measure accuracy and runtime. The kind of analysis you'd do before choosing a pricer for a production system.",
        "project-3":
          "Most quant projects stop at I built a model. This one asks what comes after — how do you know the signal is still working next month? I built the monitoring layer: rolling AUC tracking, feature importance drift detection, served as an API. Closer to what a systematic desk actually runs than anything with a P&L curve.",
        "project-4": "I picked this because spatial + temporal data is underrepresented in most DS portfolios. The interesting challenge was defining anomaly without labels — you can't just label a demand spike as bad, context matters. Isolation Forest handles this well, and SHAP made the results actually interpretable rather than just a score.",
        "project-5": "StatsBomb data is surprisingly rich — every pass, carry, and pressure with x/y coordinates. I built a proper feature store first (rolling per-90 metrics, workload proxies), then trained with walk-forward validation so there's no temporal leakage. The clustering was the most fun part — watching archetypes emerge from the data without telling the model what positions exist.",
        "project-6": "Placeholder project dialogue.",
        "project-7": "Placeholder project dialogue.",
        "project-8": "Placeholder project dialogue.",
        "project-9": "Placeholder project dialogue.",
      };

      const ALL_ANIMATIONS = [...EMOTES, ...STATES];

      document.querySelectorAll("[data-info-trigger]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const card = btn.closest(".project-card");
          const id = card.getAttribute("data-id");

          const randomEmote =
            ALL_ANIMATIONS[Math.floor(Math.random() * ALL_ANIMATIONS.length)];
          const randomExpression =
            EXPRESSIONS[Math.floor(Math.random() * EXPRESSIONS.length)];

          window.dispatchEvent(
            new CustomEvent("robot-emote", {
              detail: {
                name: randomEmote,
                text: PROJECT_DIALOGUES[id],
                expression: randomExpression,
              },
            }),
          );
        });
      });

      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const navIndicator = document.getElementById("navIndicator");
      const cards = document.querySelectorAll(".project-card");
      const totalProjects = 8;
      const projectsPerPage = 4;
      let currentPage = 0;

      function showPage(page) {
        cards.forEach((card, index) => {
          const start = page * projectsPerPage;
          const end = start + projectsPerPage;
          if (index >= start && index < end) {
            card.classList.remove("hidden");
          } else {
            card.classList.add("hidden");
          }
        });
        const startNum = page * projectsPerPage + 1;
        const endNum = Math.min((page + 1) * projectsPerPage, totalProjects);
        navIndicator.textContent = startNum + "-" + endNum;

        prevBtn.disabled = page === 0;
        nextBtn.disabled = page === 1;
      }

      if (prevBtn && nextBtn) {
        showPage(currentPage);

        prevBtn.addEventListener("click", () => {
          if (currentPage > 0) {
            currentPage--;
            showPage(currentPage);
          }
        });

        nextBtn.addEventListener("click", () => {
          if (currentPage < 1) {
            currentPage++;
            showPage(currentPage);
          }
        });
      }
    }

    initPage();
    document.addEventListener("astro:page-load", initPage);
  })();
</script>

<style>
  .projects-container {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

.projects-container::before {
    content: '';
    position: fixed;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background-color: #c8dfc8;
    background-image: repeating-conic-gradient(#b8d4b8 0% 25%, #d8ecd8 0% 50%);
    background-size: 80px 80px;
    transform: rotate(45deg);
    z-index: -1;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .back-link:hover {
    background: #000000;
    color: #ffffff;
  }

  .projects-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .nav-arrow {
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
  }

  .nav-arrow:hover {
    background: #000000;
    color: #ffffff;
  }

  .nav-arrow:disabled {
    background: #c0c0c0;
    color: #808080;
    cursor: not-allowed;
    border-color: #808080 #ffffff #ffffff #808080;
  }

  .nav-arrow:disabled:hover {
    background: #c0c0c0;
    color: #808080;
  }

  .nav-indicator {
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
    min-width: 2.5rem;
    text-align: center;
  }

  .projects-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 1rem;
    justify-content: flex-start;
    overflow-x: hidden;
    padding-bottom: 1rem;
  }

  .project-card {
    border: 2px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    padding: 0;
    width: 28rem;
    max-width: 28rem;
    min-height: 550px;
    flex-shrink: 0;
    background: #c0c0c0;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    font-size: 1rem;
    display: flex;
    flex-direction: column;
  }

  .project-card.hidden {
    display: none;
  }

  .card-header {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 0.5rem 1rem;
    background: #000033;
    gap: 0.5rem;
  }

  .card-prefix {
    color: #ffffff;
    font-size: 14px;
  }

  .card-header h2 {
    font-size: 14px;
    color: #ffffff;
    margin: 0;
    font-weight: normal;
    flex-grow: 1;
  }

  .info-btn-ui {
    background: #d8d9ed;
    border: 1px solid #000000;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: Arial, Helvetica, sans-serif;
    padding: 0.25rem 0.5rem;
    min-width: 1.5rem;
    text-align: center;
  }

  .info-btn-ui:hover {
    background: #000033;
    color: #ffffff;
  }

  .project-description {
    color: #000000;
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    padding: 1rem;
    flex-grow: 1;
  }

  .tech-tag {
    font-size: 12px;
    padding: 0.2rem 0.5rem;
    border: 1px solid;
    border-radius: 0;
    font-family: Arial, Helvetica, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-right: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .link-btn {
    color: #0000FF;
    text-decoration: underline;
  }

  .card-footer {
    padding: 1rem;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .link-btn:hover {
    color: #ff0000;
  }

  @media (max-width: 768px) {
    .projects-grid {
      flex-wrap: nowrap;
      overflow-x: auto;
    }
    .project-card {
      width: 280px;
    }
  }
</style>
