---
import Layout from "../layouts/Layout.astro";
import AvatarCurator from "../components/AvatarCurator.astro";

const projects = [
  {
    id: "project-1",
    type: "trading",
    title: "RBL Capital",
    description: `A simulated proprietary trading research system built to explore systematic edge across asset classes. Currently in active development across four research desks:<br><br><span class="desk-name">Prediction Markets</span> - real-time order flow imbalance monitoring on Polymarket, testing whether anomalous informed flow leads correlated TradFi instrument moves ahead of macro events.<br><br><span class="desk-name">Macro Signals</span> - forked Tauric Research agent framework scanning defence, infrastructure, and commodities for sentiment-driven positioning signals.<br><br><span class="desk-name">Equities</span> - agent-monitored low-frequency long/short ideas on individual stocks, fundamentals and macro-regime aware.<br><br><span class="desk-name">Mid-freq Crypto</span> - systematic signal research on Hyperliquid perpetuals.`,
    links: [
      {
        label: "Prediction Markets - Ingestion & Research",
        url: "https://github.com/kadam-x/prediction-market-algo",
      },
      {
        label: "Tauric Research Fork",
        url: "https://github.com/kadam-x/TradingAgents",
      },
    ],
  },
  {
    id: "project-2",
    type: "engineering",
    title: "Implied Volatility Surface Pipeline",
    description:
      "A full data engineering pipeline that ingests SPY options chain data daily, inverts Black-Scholes to compute implied volatility across all strikes and expiries, and stores results in a star-schema warehouse served via REST API and Grafana dashboard.",
    links: [
      {
        label: "View Code",
        url: "https://github.com/kadam-x/volatility-surface-pipeline",
      },
      {
        label: "Docs",
        url: "https://github.com/kadam-x/volatility-surface-pipeline/blob/main/docs/architecture.md",
      },
    ],
  },
  {
    id: "project-3",
    type: "game",
    span: 2,
    title: "DUAL//CORE",
    description:
      "A dual-screen arcade shooter where you control two ships simultaneously - one on each side of the screen. Each ship mirrors the other's movement but fires in opposite directions. Survive waves of enemies, manage shared resources between both cores, and unlock new weapon combinations as you progress.",
    links: [
      {
        label: "Devlog",
        url: "",
      },
    ],
  },
  /* {
    id: "project-5",
    title: "CopyBot",
    description:
      "A Python-based system for monitoring, analyzing, and optimizing Solana copy-trading wallets using real-time on-chain data and post-trade performance tracking. It ingests real-time wallet activity via webhooks, enriches trades with market and risk data, and tracks post-purchase token performance using delayed OHLCV analysis.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Solana", color: "#9945FF" },
      { name: "Webhooks", color: "#a1cd5e" },
      { name: "Async", color: "#a1cd5e" },
    ],
    links: [
      {
        label: "View Code",
        url: "https://github.com/snezzz0/solana-wallet-tracker-old/",
      },
    ],
  },
  {
    id: "project-6",
    title: "Siege X Guide",
    description:
      "Interactive Rainbow Six Siege tactical guide featuring comprehensive map callouts, operator strategies, and gameplay tips for competitive players. Built with Next.js 15 featuring smooth animations with Framer Motion.",
    techStack: [
      { name: "React", color: "#61DAFB" },
      { name: "Next.js", color: "#000000" },
      { name: "TypeScript", color: "#3178C6" },
      { name: "Framer", color: "#0055FF" },
    ],
    links: [
      { label: "Live Demo", url: "https://siege-x-guide.vercel.app/" },
      { label: "View Code", url: "https://github.com/snezzz0/siegex" },
    ],
  }, */
];
---

<Layout
  title="Kovacs Adam :: Projects"
  showProfile={false}
  useGridBackground={true}
>
  <AvatarCurator transition:persist />

  <main class="projects-container">
    <div class="top-bar">
      <a href="/hero" class="back-link" id="homeLink"> &lt; take me home </a>

      <div class="projects-nav">
        <button class="nav-arrow" id="prevBtn">&lt; prev</button>
        <button class="nav-arrow" id="nextBtn">next &gt;</button>
      </div>
    </div>

    <div class="projects-sidebar active">
      <div class="projects-grid">
        {
          projects.map((project, index) => (
            <div
              class="project-card"
              data-id={project.id}
              data-index={index}
              data-type={project.type}
              data-span={project.span || 1}
            >
              <div class="card-header">
                <span class="card-prefix">[*]</span>
                <h2>{project.title}</h2>
                <button
                  class="info-btn-ui"
                  data-info-trigger
                  aria-label="Project Info"
                >
                  ?
                </button>
              </div>

              {!project.isLearning && (
                <div class="video-placeholder">
                  <span>Live Demo</span>
                </div>
              )}

              <p class="project-description" set:html={project.description} />

              <div class="card-footer">
                <div class="card-links">
                  {project.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="link-btn"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function () {
    function robotReact(emoteName) {
      window.dispatchEvent(
        new CustomEvent("robot-emote", {
          detail: { name: emoteName },
        }),
      );
    }

    function initPage() {
      const homeLink = document.getElementById("homeLink");

      if (homeLink) {
        homeLink.addEventListener("mouseenter", () => robotReact("Wave"));
      }

      const EMOTES = ["Jump", "Yes", "No", "Wave", "ThumbsUp"];
      const STATES = ["Dance"];
      const EXPRESSIONS = ["talking"];
      const PROJECT_DIALOGUES = {
        "project-1":
          "I built this because prediction markets and DeFI are one of the few places where insider positioning is both legal and detectable. The real question is not whether the retail can catch up in time",
        "project-2":
          "Two ships. One keyboard. Zero mercy. Been wanting to build a dual-screen shooter since I played those old flash games. The core mechanic of mirrored movement but opposite firing directions creates this puzzle-like flow where you have to think about both sides simultaneously.",
        "project-3":
          "I wanted to build something that sits closer to how risk systems actually work than a typical portfolio project. Fetching the chain, inverting Black-Scholes numerically per strike, warehousing it properly, serving it through an API. Getting Brent's method to behave at the wings was the part that kept me up.",
      };

      const ALL_ANIMATIONS = [...EMOTES, ...STATES];

      document.querySelectorAll("[data-info-trigger]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const card = btn.closest(".project-card");
          const id = card.getAttribute("data-id");

          const randomEmote =
            ALL_ANIMATIONS[Math.floor(Math.random() * ALL_ANIMATIONS.length)];
          const randomExpression =
            EXPRESSIONS[Math.floor(Math.random() * EXPRESSIONS.length)];

          window.dispatchEvent(
            new CustomEvent("robot-emote", {
              detail: {
                name: randomEmote,
                text: PROJECT_DIALOGUES[id],
                expression: randomExpression,
              },
            }),
          );
        });
      });

      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const cards = document.querySelectorAll(".project-card");

      const pageLayout = [[0, 1], [2]];
      const totalPages = pageLayout.length - 1;
      let currentPage = 0;

      function showPage(page) {
        const visibleIndices = pageLayout[page] || [];
        cards.forEach((card, index) => {
          if (visibleIndices.includes(index)) {
            card.classList.remove("hidden");
          } else {
            card.classList.add("hidden");
          }
        });

        prevBtn.disabled = page === 0;
        nextBtn.disabled = page === totalPages;
      }

      if (prevBtn && nextBtn) {
        showPage(currentPage);

        prevBtn.addEventListener("click", () => {
          if (currentPage > 0) {
            currentPage--;
            showPage(currentPage);
          }
        });

        nextBtn.addEventListener("click", () => {
          if (currentPage < totalPages) {
            currentPage++;
            showPage(currentPage);
          }
        });
      }
    }

    initPage();
    document.addEventListener("astro:page-load", initPage);
  })();
</script>

<style>
  .projects-container {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    padding: 3rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    width: 100%;
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    margin-left: 3rem;
  }

  .back-link:hover {
    background: #000000;
    color: #ffffff;
  }

  .projects-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-right: 6rem;
  }

  .nav-arrow {
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
  }

  .nav-arrow:hover {
    background: #000000;
    color: #ffffff;
  }

  .nav-arrow:disabled {
    background: #c0c0c0;
    color: #808080;
    cursor: not-allowed;
    border-color: #808080 #ffffff #ffffff #808080;
  }

  .nav-arrow:disabled:hover {
    background: #c0c0c0;
    color: #808080;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    gap: 1rem;
    justify-content: flex-end;
    align-items: flex-end;
    padding-bottom: 1rem;
    padding-right: 6rem;
  }

  .project-card {
    border: 2px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    padding: 0;
    width: 80rem;
    max-width: 80rem;
    min-height: 360px;
    flex-shrink: 0;
    background: #c0c0c0;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    font-size: 1rem;
    display: flex;
    flex-direction: column;
  }

  .project-card[data-span="2"] {
    min-height: calc(360px + 1rem);
  }

  .project-card[data-type="game"] {
    background: #1a1a2e;
    border-color: #0f0f1a #4a4a6a #4a4a6a #0f0f1a;
  }

  .project-card[data-type="game"] .card-header {
    background: #0f0f1a;
  }

  .project-card[data-type="game"] .card-header h2 {
    color: #00ff88;
  }

  .project-card[data-type="game"] .card-prefix {
    color: #00ff88;
  }

  .project-card[data-type="game"] .project-description {
    color: #e0e0e0;
  }

  .project-card.hidden {
    display: none;
  }

  .card-header {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 0.5rem 1rem;
    background: #000033;
    gap: 0.5rem;
  }

  .card-prefix {
    color: #ffffff;
    font-size: 14px;
  }

  .card-header h2 {
    font-size: 14px;
    color: #ffffff;
    margin: 0;
    font-weight: normal;
    flex-grow: 1;
  }

  .info-btn-ui {
    background: #c0c0c0;
    border: 1px solid;
    border-color: #ffffff #000000 #000000 #ffffff;
    color: #000000;
    font-size: 1rem;
    cursor: pointer;
    font-family: "MS Sans Serif", "Segoe UI", sans-serif;
    padding: 0.25rem 0.5rem;
    min-width: 1.5rem;
    text-align: center;
  }

  .info-btn-ui:hover {
    background: #000000;
    color: #ffffff;
  }

  .project-description {
    color: #000000;
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    padding: 1rem;
    flex-grow: 1;
  }

  .project-description :global(.desk-name) {
    font-weight: bold;
    color: #000033;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .link-btn {
    color: #0000ff;
    text-decoration: underline;
  }

  .card-footer {
    padding: 1rem;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .link-btn:hover {
    color: #ff0000;
  }

  @media (max-width: 768px) {
    .projects-grid {
      flex-wrap: nowrap;
      overflow-x: auto;
    }
    .project-card {
      width: 280px;
    }
  }
</style>
