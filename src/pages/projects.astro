---
import Layout from "../layouts/Layout.astro";
import RobotCurator from "../components/RobotCurator.astro";

const projects = [
  {
    id: "project-1",
    title: "CopyBot",
    description:
      "A Python-based system for monitoring, analyzing, and optimizing Solana copy-trading wallets using real-time on-chain data and post-trade performance tracking. It ingests real-time wallet activity via webhooks, enriches trades with market and risk data, and tracks post-purchase token performance using delayed OHLCV analysis.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Solana", color: "#9945FF" },
      { name: "Webhooks", color: "#a1cd5e" },
      { name: "Async", color: "#a1cd5e" },
    ],
    links: [
      {
        label: "View Code",
        url: "https://github.com/snezzz0/solana-wallet-tracker-old/",
      },
    ],
  },
  {
    id: "project-2",
    title: "Obscuratee",
    description:
      "A whimsical terminal application that brings colorful ASCII manatees to your command line, delivering marine-inspired wisdom with questionable accuracy. Featuring multiple display modes including legacy ASCII art, vibrant color modes, and special curse effects.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "PyPI", color: "#F7B731" },
      { name: "ANSI", color: "#a1cd5e" },
    ],
    links: [
      { label: "PyPI Package", url: "https://pypi.org/project/obscuratee/" },
      { label: "View Code", url: "https://github.com/snezzz0/obscuratee" },
    ],
  },
  {
    id: "project-3",
    title: "Siege X Guide",
    description:
      "Interactive Rainbow Six Siege tactical guide featuring comprehensive map callouts, operator strategies, and gameplay tips for competitive players. Built with Next.js 15 featuring smooth animations with Framer Motion.",
    techStack: [
      { name: "React", color: "#61DAFB" },
      { name: "Next.js", color: "#000000" },
      { name: "TypeScript", color: "#3178C6" },
      { name: "Framer", color: "#0055FF" },
    ],
    links: [
      { label: "Live Demo", url: "https://siege-x-guide.vercel.app/" },
      { label: "View Code", url: "https://github.com/snezzz0/siegex" },
    ],
  },
  {
    id: "project-4",
    title: "Sales Data Analysis",
    description:
      "Analyzed retail sales data using Python and pandas to uncover trends in seasonality, customer behavior, and product performance.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "Pandas", color: "#150458" },
    ],
    links: [
      { label: "View Code", url: "https://github.com/snezzz0/sales-data-analysis" },
    ],
  },
  {
    id: "project-5",
    title: "Arbitrage Bot",
    description:
      "A Bloomberg style crypto arbitrage bot using CoinGecko's API, Binance's API calculates spread and visualizes 24H data.",
    techStack: [
      { name: "Python", color: "#3776AB" },
      { name: "API", color: "#F7B731" },
    ],
    links: [
      { label: "View Code", url: "https://github.com/snezzz0/crypto-arbitrage-test" },
    ],
  },
  // { id: 'project-5', title: 'Project Five', description: 'Description for project 5.', techStack: [], links: [] },
  // { id: 'project-6', title: 'Project Six', description: 'Description for project 6.', techStack: [], links: [] },
  // { id: 'project-7', title: 'Project Seven', description: 'Description for project 7.', techStack: [], links: [] },
  // { id: 'project-8', title: 'Project Eight', description: 'Description for project 8.', techStack: [], links: [] },
];
---

<Layout title="Kovacs Adam :: Projects" backgroundColor="#030210">
  <RobotCurator />

  <main class="projects-container">
    <div class="nav-buttons">
      <a href="/" class="back-link" id="homeLink">
        <span class="arrow">←</span>
        <span>take me home</span>
      </a>
    </div>

    <div class="projects-sidebar active">
      <div class="projects-grid">
        {
          projects.map((project, index) => (
            <div class="project-card" data-id={project.id}>
              <div class="card-header">
                <h2>{project.title}</h2>
                <button
                  class="info-btn-ui"
                  data-info-trigger
                  aria-label="Project Info"
                >
                  ?
                </button>
              </div>

              {!project.isLearning && (
                <div class="video-placeholder">
                  <span>Live Demo</span>
                </div>
              )}

              <p class="project-description">{project.description}</p>

              <div class="card-footer">
                <div class="tech-stack">
                  {project.techStack.map((tech) => (
                    <span
                      class="tech-tag"
                      style={`background-color: ${tech.color}20; border-color: ${tech.color}40; color: ${tech.color};`}
                    >
                      {tech.name}
                    </span>
                  ))}
                </div>

                <div class="card-links">
                  {project.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="link-btn"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function () {
    function robotReact(emoteName) {
      window.dispatchEvent(
        new CustomEvent("robot-emote", {
          detail: { name: emoteName },
        }),
      );
    }

    function initPage() {
      const homeLink = document.getElementById("homeLink");

      if (homeLink) {
        homeLink.addEventListener("mouseenter", () => robotReact("Wave"));
      }

      const EMOTES = ["Jump", "Yes", "No", "Wave", "ThumbsUp"];
      const STATES = ["Dance"];
      const EXPRESSIONS = ["Surprised", "Sad"];
      const PROJECT_DIALOGUES = {
        "project-1":
          "I built a system that tracks Solana wallets, measures real trade performance, and replaces underperformers using on-chain data.",
        "project-2": "Fully typed with TypeScript. No 'any' allowed here!",
        "project-3":
          "I built this to quickly reveal meta gadget placements for operators, ensuring players can master those game-changing tactical positions.",
        "project-4": "Analyzed retail sales data using Python and pandas to uncover trends in seasonality.",
        "project-5": "A crypto arbitrage bot using CoinGecko and Binance APIs.",
      };

      const ALL_ANIMATIONS = [...EMOTES, ...STATES];

      document.querySelectorAll("[data-info-trigger]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const card = btn.closest(".project-card");
          const id = card.getAttribute("data-id");

          const randomEmote =
            ALL_ANIMATIONS[Math.floor(Math.random() * ALL_ANIMATIONS.length)];
          const randomExpression =
            EXPRESSIONS[Math.floor(Math.random() * EXPRESSIONS.length)];

          window.dispatchEvent(
            new CustomEvent("robot-emote", {
              detail: {
                name: randomEmote,
                text: PROJECT_DIALOGUES[id],
                expression: randomExpression,
              },
            }),
          );
        });
      });
    }

    initPage();
    document.addEventListener("astro:page-load", initPage);
  })();
</script>

<style>
  .projects-container {
    position: relative;
    z-index: 10;
    min-height: 100vh;
  }
  .nav-buttons {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 20;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #a1cd5e;
    text-decoration: none;
    font-family: "Fira Code", monospace;
    font-size: 1rem;
  }

  .back-link:hover {
    color: #ff5454;
  }

  .projects-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    padding: 4rem 2rem;
    overflow-x: auto;
    overflow-y: hidden;
    z-index: 15;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }
  .projects-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 1.75rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
    padding-left: 2rem;
    width: max-content;
  }

  .project-card {
    background: #0c0e14;
    border: 3px solid #0c0e14;
    padding: 2rem 1.5rem;
    color: inherit;
    position: relative;
    display: flex;
    flex-direction: column;
    width: 400px;
    flex-shrink: 0;
    height: 780px;
    overflow-y: auto;
  }

  .project-card:hover {
    border-color: #80a0ff;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .video-placeholder {
    width: 100%;
    height: 120px;
    background: #030210;
    border: 2px dashed #0c0e14;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: #626467;
    font-family: "Fira Code", monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .card-header h2 {
    font-size: 1.5rem;
    color: #80a0ff;
    margin: 0;
    line-height: 1.3;
  }

  .project-description {
    color: #bdbdbd;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 1rem 0;
    flex-grow: 0;
  }

  .tech-tag {
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid;
    border-radius: 3px;
    font-family: "Fira Code", monospace;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .link-btn {
    font-size: 0.75rem;
    padding: 0.4rem 0.7rem;
    border: 1px solid #80a0ff;
    color: #80a0ff;
    text-decoration: none;
    font-family: "Fira Code", monospace;
    transition: all 0.2s;
  }

  .info-btn-ui {
    background: transparent;
    border: 2px solid #0c0e14;
    color: #626467;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    font-family: "Fira Code", monospace;
    font-weight: bold;
    font-size: 0.8rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .info-btn-ui:hover {
    background: #0c0e14;
    border-color: #ff5454;
    color: #ff5454;
  }

  .project-description {
    color: #bdbdbd;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 1rem 0;
    flex-grow: 0;
  }

  .card-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid;
    border-radius: 3px;
    font-family: "Fira Code", monospace;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .link-btn {
    font-size: 0.7rem;
    padding: 0.35rem 0.6rem;
    border: 1px solid #80a0ff;
    color: #80a0ff;
    text-decoration: none;
    font-family: "Fira Code", monospace;
    transition: all 0.2s;
  }

  .link-btn:hover {
    background: #80a0ff;
    color: #030210;
  }

  @media (max-width: 768px) {
    .projects-sidebar {
      overflow-x: hidden;
      overflow-y: auto;
      align-items: flex-start;
    }
    .projects-grid {
      flex-direction: column;
      width: 100%;
      padding-left: 0;
      justify-items: center;
      flex-wrap: wrap;
    }
    .project-card {
      width: 100%;
      max-width: 400px;
      height: auto;
      min-height: 500px;
    }
  }
</style>
