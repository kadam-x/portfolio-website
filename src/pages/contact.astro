---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kovacs Adam :: Contact" backgroundColor="#030210">
  <main class="contact-container" id="page-wrapper">
    <a href="/" class="back-link">
      <span class="arrow">[<</span>
      <span>take me home</span>
      <span class="arrow">]</span>
    </a>

    <div class="contact-box">
      <div class="box-header">[*] CONTACT_MENU</div>
      <div class="social-links">
        <div class="contact-row">
          <span class="row-label">[01]</span>
          <span class="row-text">email</span>
          <button id="copy-email" class="clickable" data-email="kadamx@proton.com">
            kadamx [at] proton [dot] com
          </button>
        </div>
        <div class="contact-row">
          <span class="row-label">[02]</span>
          <span class="row-text">github</span>
          <a href="https://github.com/kadam-x" target="_blank" class="clickable">
            @kadam-x
          </a>
        </div>
        <div class="contact-row">
          <span class="row-label">[03]</span>
          <span class="row-text">linkedin</span>
          <a href="https://www.linkedin.com/in/kvcs-adam-s/" target="_blank" class="clickable">
            @Adam Kovacs
          </a>
        </div>
        <div class="contact-row">
          <span class="row-label">[04]</span>
          <span class="row-text">leetcode</span>
          <a href="https://leetcode.com/u/kadam-x/" target="_blank" class="clickable">
            @kadam-x
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const initTerminal = () => {
    const input = document.getElementById("terminal-input") as HTMLInputElement;
    const history = document.getElementById("terminal-history");
    const consoleElem = document.getElementById("main-console");
    const wrapper = document.getElementById("page-wrapper");
    const cursor = document.getElementById("custom-cursor");
    const emailBtn = document.getElementById("copy-email");
    const copyHint = document.getElementById("copy-hint");

    if (
      !input ||
      !history ||
      !consoleElem ||
      !wrapper ||
      !cursor ||
      !emailBtn ||
      input.dataset.initialized
    )
      return;

    emailBtn.addEventListener("click", () => {
      const email = emailBtn.getAttribute("data-email") || "";
      navigator.clipboard.writeText(email).then(() => {
        copyHint.textContent = "(copied!)";
        setTimeout(() => {
          copyHint.textContent = "(click to copy)";
        }, 2000);
      });
    });

    // Cursor Tracking logic
    const updateCursor = () => {
      cursor.style.setProperty("--char-count", input.value.length.toString());
    };

    const COMMANDS = {
      help: "Available commands: neofetch, matrix, ls, ping, clear",
      ls: "about.md  projects.bin  contact.sh  secret_plans.txt",
      ping: "64 bytes from 127.0.0.1: icmp_seq=1 ttl=64 time=0.042 ms",
      matrix: "Wake up, Neo... The matrix has you.",
      sudo: "Nice try. This incident will be reported.",
      "cd ~": "Redirecting to root...",
      "cd ..": "Redirecting to root...",
    };

    const typeWriter = (text, element, speed = 15) => {
      let i = 0;
      if (text.includes("\n")) element.style.whiteSpace = "pre";
      const interval = setInterval(() => {
        if (i < text.length) {
          element.innerHTML += text.charAt(i);
          i++;
          history.scrollTop = history.scrollHeight;
        } else {
          clearInterval(interval);
        }
      }, speed);
    };

    const runFullMatrixMode = () => {
      history.innerHTML = "";
      wrapper.classList.add("global-matrix-mode");
      document.body.classList.add("global-matrix-mode");
      const wakeUpText = "WAKE UP. ".repeat(60);
      const response = document.createElement("p");
      response.className = "matrix-text-flood";
      history.appendChild(response);
      typeWriter(wakeUpText, response, 5);

      setTimeout(() => {
        wrapper.classList.remove("global-matrix-mode");
        document.body.classList.remove("global-matrix-mode");
        history.innerHTML = "";
        const p = document.createElement("p");
        p.className = "sys-msg";
        p.textContent = "Connection restored. Buffer cleared.";
        history.appendChild(p);
      }, 5000);
    };

    const welcomeMsgs = [
      "Initializing experimental_environment...",
      "Secure socket established.",
      'Type "help" for available commands.',
    ];

    welcomeMsgs.forEach((msg, i) => {
      setTimeout(() => {
        const p = document.createElement("p");
        p.className = "sys-msg";
        history.appendChild(p);
        typeWriter(msg, p, 10);
      }, i * 500);
    });

    input.addEventListener("input", updateCursor);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const val = input.value.toLowerCase().trim();
        const line = document.createElement("div");
        line.innerHTML = `<span class="user-input">> ${val}</span>`;
        history.appendChild(line);

        if (val === "clear") {
          history.innerHTML = "";
        } else if (val === "matrix") {
          runFullMatrixMode();
        } else if (val === "neofetch") {
          const neoDiv = document.createElement("div");
          neoDiv.className = "cmd-response";
          neoDiv.style.whiteSpace = "pre";
          neoDiv.innerHTML = `<span style="color: #a1cd5e; font-weight: bold;">snezzz@moonfly</span>
------------------
<span style="color: #a1cd5e;">WHOAMI:</span> Developer, builder, learner.
<span style="color: #a1cd5e;">DOTFILES:</span> <a href="https://github.com/kadam-x/dots-nixos" target="_blank" class="term-link">https://github.com/kadam-x/dots-nixos</a>
<span style="color: #a1cd5e;">EDITOR</span> nvim 
<span style="color: #a1cd5e;">SHELL:</span> zsh
<span style="color: #a1cd5e;">UPTIME:</span> 13h 37m`;
          history.appendChild(neoDiv);
          history.scrollTop = history.scrollHeight;
        } else if (COMMANDS[val]) {
          const response = document.createElement("p");
          response.className = "cmd-response";
          history.appendChild(response);
          typeWriter(COMMANDS[val], response);
        } else if (val !== "") {
          const err = document.createElement("p");
          history.appendChild(err);
          typeWriter(`zsh: command not found: ${val}`, err);
        }

        input.value = "";
        updateCursor();
      }
    });

    consoleElem.addEventListener("click", () => input.focus());
    input.dataset.initialized = "true";
  };

  initTerminal();
  document.addEventListener("astro:page-load", initTerminal);
</script>

<style>
  .contact-container {
    min-height: 100vh;
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #a1cd5e;
    text-decoration: none;
    font-size: 0.7rem;
    margin-bottom: 3rem;
  }
  .back-link:hover {
    color: #ff5454;
  }
  .arrow {
    color: #a1cd5e;
  }

  .contact-box {
    border: 4px solid #a1cd5e;
    padding: 0;
    background: #030210;
  }

  .box-header {
    background: #a1cd5e;
    color: #030210;
    padding: 0.75rem 1rem;
    font-size: 0.7rem;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-bottom: 1px solid #323437;
  }

  .contact-row:last-child {
    border-bottom: none;
  }

  .row-label {
    color: #a1cd5e;
    min-width: 50px;
    font-size: 0.7rem;
  }

  .row-text {
    color: #80a0ff;
    min-width: 70px;
    font-size: 0.7rem;
  }

  .clickable {
    color: #b2b2b2;
    text-decoration: none;
    transition: color 0.15s;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 0.7rem;
    padding: 0;
  }

  .clickable:hover {
    color: #80a0ff;
  }

  .floating-console {
    background: #0c0c0c;
    border: 2px solid #b2b2b2;
    width: 100%;
    max-width: 750px;
    margin: 0 auto;
    position: relative;
    transition: all 0.5s ease;
  }

  .console-border-top {
    background: rgba(178, 178, 178, 0.15);
    padding: 0.6rem 1.2rem;
    border-bottom: 2px solid #0c0c0c;
  }
  .console-label {
    font-size: 0.7rem;
    color: #b2b2b2;
    letter-spacing: 1px;
    font-weight: bold;
  }

  #terminal-history {
    height: 380px;
    padding: 1.5rem;
    overflow-y: auto;
    font-size: 0.95rem;
    color: #b2b2b2;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-line {
    padding: 0 1.5rem 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .input-wrapper {
    position: relative;
    display: flex;
    flex-grow: 1;
    align-items: center;
  }

  #terminal-input {
    background: transparent;
    border: none;
    outline: none;
    color: #b2b2b2;
    font-family: inherit;
    font-size: 1rem;
    width: 100%;
    caret-color: transparent;
  }

  #custom-cursor {
    position: absolute;
    left: 0;
    width: 1ch;
    height: 1.2rem;
    background: #82aaff;
    animation: blink 1s step-end infinite;
    transform: translateX(calc(var(--char-count, 0) * 1ch));
  }

  @keyframes blink {
    from,
    to {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .prompt {
    color: #b2b2b2;
  }
  .user-input {
    color: #82aaff;
  }
  .cmd-response {
    color: #b2b2b2;
    line-height: 1.6;
  }
  .sys-msg {
    color: #b2b2b2;
    font-style: italic;
    opacity: 0.8;
  }
  .term-link {
    color: #82aaff;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Matrix Mode */
  .global-matrix-mode {
    background-color: #000000 !important;
  }
  body.global-matrix-mode {
    background-color: #000000 !important;
  }
  .global-matrix-mode .social-links,
  .global-matrix-mode .back-link {
    opacity: 0;
    pointer-events: none;
  }
  .global-matrix-mode .floating-console {
    max-width: 900px;
    border-color: #00ff41;
    background: #000;
    box-shadow: 0 0 30px rgba(0, 255, 65, 0.3);
  }
  .global-matrix-mode .console-border-top {
    border-color: #00ff41;
  }
  .global-matrix-mode .console-label,
  .global-matrix-mode .prompt,
  .global-matrix-mode .user-input,
  .global-matrix-mode #terminal-input,
  .global-matrix-mode #terminal-history {
    color: #00ff41 !important;
  }
  .global-matrix-mode #custom-cursor {
    background: #00ff41 !important;
  }
  .matrix-text-flood {
    color: #00ff41;
    font-weight: bold;
    word-break: break-all;
  }

  @media (max-width: 768px) {
    .floating-console {
      max-width: 100%;
    }
    .social-link {
      width: 100%;
    }
  }
</style>
