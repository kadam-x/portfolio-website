---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kovacs Adam :: Contact" backgroundColor="#030210">
  <main class="contact-container" id="page-wrapper">
    <a href="/" class="back-link">
      <span class="arrow">[<</span>
      <span>take me home</span>
      <span class="arrow">]</span>
    </a>

    <div class="contact-box">
      <div class="box-header">[*] CONTACT_MENU</div>
      <div class="social-links">
        <div class="contact-row">
          <span class="row-label">[01]</span>
          <span class="row-text">email</span>
          <button id="copy-email" class="clickable" data-email="kadamx@proton.com">
            kadamx [at] proton [dot] com
          </button>
          <span id="copy-hint" class="copy-hint">(click to copy)</span>
        </div>
        <div class="contact-row">
          <span class="row-label">[02]</span>
          <span class="row-text">github</span>
          <a href="https://github.com/kadam-x" target="_blank" class="clickable">
            @kadam-x
          </a>
        </div>
        <div class="contact-row">
          <span class="row-label">[03]</span>
          <span class="row-text">linkedin</span>
          <a href="https://www.linkedin.com/in/kvcs-adam-s/" target="_blank" class="clickable">
            @Adam Kovacs
          </a>
        </div>
        <div class="contact-row">
          <span class="row-label">[04]</span>
          <span class="row-text">leetcode</span>
          <a href="https://leetcode.com/u/kadam-x/" target="_blank" class="clickable">
            @kadam-x
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const emailBtn = document.getElementById("copy-email");
  const copyHint = document.getElementById("copy-hint");

  if (emailBtn && copyHint) {
    emailBtn.addEventListener("click", () => {
      const email = emailBtn.getAttribute("data-email") || "";
      navigator.clipboard.writeText(email).then(() => {
        copyHint.textContent = "(copied to clipboard!)";
        setTimeout(() => {
          copyHint.textContent = "(click to copy)";
        }, 2000);
      });
    });
  }
</script>

<style>
  .contact-container {
    min-height: 100vh;
    padding: 2rem 1rem;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #a1cd5e;
    text-decoration: none;
    font-size: 16px;
    margin-bottom: 1.5rem;
    font-family: Arial, Helvetica, sans-serif;
  }

  .back-link:hover {
    color: #ff5454;
  }

  .arrow {
    color: #a1cd5e;
  }

  .contact-box {
    min-width: 600px;
    border: 1px solid #000000;
    border-top: 2px solid #000000;
    padding: 0;
    background: #d8d9ed;
    width: 100%;
  }

  .box-header {
    background: #cde6a8;
    color: #0c0e14;
    padding: 0.5rem 1rem;
    font-size: 14px;
    font-family: Arial, Helvetica, sans-serif;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #000000;
    font-size: 16px;
    font-family: Arial, Helvetica, sans-serif;
  }

  .contact-row:last-child {
    border-bottom: none;
  }

  .row-label {
    color: #000000;
    min-width: 50px;
    font-size: 16px;
  }

  .row-text {
    color: #000000;
    min-width: 80px;
    font-size: 16px;
  }

  .clickable {
    color: #0000FF;
    text-decoration: underline;
    transition: color 0.15s;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 16px;
  }

  .clickable:hover {
    color: #0000aa;
  }

  .copy-hint {
    color: #000000;
    font-size: 12px;
    margin-left: 0.5rem;
  }

  @media (max-width: 768px) {
    .floating-console {
      max-width: 100%;
    }
    .social-link {
      width: 100%;
    }
  }
</style>
