---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" backgroundColor="#342331">
  <main class="contact-container">
    <a href="/" class="back-link">
      <span class="arrow">←</span>
      <span>take me home</span>
    </a>
    
    <div class="contact-box">
      <h1 class="title">get in touch</h1>
      
      <div class="contact-content">
        <div class="social-links">
          <a href="mailto:your@email.com" class="social-link">email</a>
          <a href="https://github.com/yourusername" target="_blank" class="social-link">github</a>
          <a href="https://linkedin.com/in/yourusername" target="_blank" class="social-link">linkedin</a>
          <a href="https://twitter.com/yourusername" target="_blank" class="social-link">twitter</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .contact-container {
    min-height: 100vh;
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #FFE4AF;
    font-size: 1rem;
    transition: color 0.2s;
    margin-bottom: 3rem;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
  }

  .back-link:hover {
    color: #EC753A;
  }

  .arrow {
    font-size: 1.5rem;
  }

  .contact-box {
    background: transparent;
    border: none;
    padding: 0;
  }

  .title {
    display: none;
  }

  .social-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 1rem;
  }

  .social-link {
    padding: 0.75rem;
    border: 2px solid #FFE4AF;
    background: transparent;
    color: #FFE4AF;
    text-align: center;
    transition: color 0.2s;
    text-transform: lowercase;
  }

  .social-link:hover {
    color: #EC753A;
  }

  @media (max-width: 640px) {
    .contact-box {
      padding: 1.5rem;
    }

    .title {
      font-size: 2rem;
    }
  }
</style>