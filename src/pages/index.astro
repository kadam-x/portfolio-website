  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :global(body) {
      background: #131313;
      color: #cbcbcb;
      font-family: "Courier New", Courier, monospace;
      font-size: 13px;
    }

    main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 220px 0 110px;
      gap: 16px;
      max-width: 700px;
      margin: 0 auto;
    }

    /* в”Җв”Җ portrait block в”Җв”Җ */
    .portrait-block {
      width: 100%;
      overflow: visible;
      line-height: 1.45;
      padding-left: 48px;
      padding-right: 48px;
    }

    .txt-row {
      white-space: nowrap;
      overflow: hidden;
      font-size: 11px;
      color: #cbcbcb;
      letter-spacing: 0.04em;
    }

    .middle-row {
      display: flex;
      width: 100%;
    }

    .side-txt {
      display: flex;
      flex-direction: column;
      flex: 1;
      overflow: hidden;
      white-space: nowrap;
      font-size: 11px;
      color: #cbcbcb;
      letter-spacing: 0.04em;
      line-height: 1.45;
    }

    .side-txt.right {
      text-align: right;
    }

    .img-col {
      flex-shrink: 0;
      line-height: 0;
    }

    .img-col img {
      display: block;
      width: 180px;
      height: auto;
      object-fit: cover;
    }

    /* в”Җв”Җ logo row в”Җв”Җ */
    .logo-row {
      display: flex;
      align-items: center;
      gap: 18px;
      width: 100%;
      padding: 0 16px;
    }

    .hex-col {
      display: flex;
      flex-direction: column;
      font-size: 11px;
      line-height: 1.9;
      color: #cbcbcb;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .ascii-logo {
      font-size: 11px;
      line-height: 1.5;
      color: #cbcbcb;
      white-space: pre;
      flex: 1;
      overflow: visible;
    }

    /* в”Җв”Җ nav в”Җв”Җ */
    nav {
      display: flex;
      gap: 14px;
      align-items: center;
      font-size: 14px;
      color: #cbcbcb;
    }

    nav a {
      color: #cbcbcb;
      font-weight: 700;
      text-decoration: underline;
    }

    nav a:hover {
      color: #cbcbcb;
    }

    .sep {
      color: #cbcbcb;
    }

    /* в”Җв”Җ contact в”Җв”Җ */
    .links {
      display: flex;
      flex-direction: column;
      gap: 5px;
      font-size: 13px;
      text-align: center;
      color: #cbcbcb;
    }

    .links a {
      color: #cbcbcb;
      font-weight: 700;
      text-decoration: underline;
    }

    .links a:hover {
      color: #cbcbcb;
    }

    .copy {
      color: #cbcbcb;
      font-weight: 700;
      text-decoration: underline;
      cursor: pointer;
    }

    .copy:hover {
      color: #cbcbcb;
    }

    #copy-hint {
      font-size: 11px;
      opacity: 0.35;
    }

    /* в”Җв”Җ quote в”Җв”Җ */
    .quote {
      font-size: 12px;
      color: #cbcbcb;
      text-align: center;
      line-height: 1.85;
    }

    .quote .attr {
      margin-top: 4px;
      color: #cbcbcb;
    }

    .separator {
      font-size: 11px;
      color: #cbcbcb;
      letter-spacing: 0.04em;
      line-height: 1;
    }
  </style>

  <script>
    const emailBtn = document.getElementById("copy-email");
    const copyHint = document.getElementById("copy-hint");
    emailBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("kadamx@proton.me");
        if (copyHint) {
          copyHint.textContent = "(copied!)";
          setTimeout(() => {
            copyHint.textContent = "(click to copy)";
          }, 2000);
        }
      } catch (err) {
        console.error("Failed to copy:", err);
      }
    });
  </script>
</Layout>

