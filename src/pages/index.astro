---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kovacs Adam :: Portfolio" backgroundColor="#030210">
  <div class="fireflies">
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
  </div>

  <main class="hero-container">
    <div class="center-box">
      <div class="welcome-header">
        <span class="welcome-text">WELCOME</span>
      </div>

      <nav class="nav-links">
        <a href="/about" class="nav-link">who am I</a>
        <a href="/projects" class="nav-link">my projects</a>
        <a href="/contact" class="nav-link">contact me</a>
      </nav>

      <div class="color-palette">
        <div
          class="color-square"
          data-color="#030210"
          style="background-color: #030210;"
        >
        </div>
        <div
          class="color-square"
          data-color="#323437"
          style="background-color: #323437;"
        >
        </div>
        <div
          class="color-square"
          data-color="#ff5454"
          style="background-color: #ff5454;"
        >
        </div>
        <div
          class="color-square"
          data-color="#80a0ff"
          style="background-color: #80a0ff;"
        >
        </div>
        <div
          class="color-square"
          data-color="#a1cd5e"
          style="background-color: #a1cd5e;"
        >
        </div>
      </div>
    </div>
  </main>

  <style>
    .hero-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
      z-index: 1;
    }

    .center-box {
      padding: 3rem;
      min-width: 400px;
      display: flex;
      flex-direction: column;
      gap: 3rem;
      position: relative;
    }

    .welcome-header {
      text-align: center;
      margin: 0 auto;
      margin-bottom: 0rem;
      border: 2px solid #323437;
      padding: 1.2rem 9.2rem;
      background: #030210;
      display: inline-block;
    }

    .welcome-text {
      font-size: 1.5rem;
      font-weight: 700;
      color: #80a0ff;
      letter-spacing: 0.1em;
    }

    .nav-links {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem 4.9rem;
      margin: 0 auto;
      background: #030210;
      border: 20px solid #a1cd5e;
      position: relative;
    }

    .nav-links::before,
    .nav-links::after {
      content: "";
      position: absolute;
      left: 15%;
      right: 15%;
      background: #030210;
      height: 20px;
    }

    /* Position the top eraser over the top border */
    .nav-links::before {
      top: -20px;
    }

    /* Position the bottom eraser over the bottom border */
    .nav-links::after {
      bottom: -20px;
    }

    .nav-link {
      font-size: 1.8rem;
      color: #a1cd5e;
      text-align: center;
      transition: all 0.2s;
      padding: 0.5rem;
      font-family: "Fira Code", "FiraCode Nerd Font", monospace;
      z-index: 1;
    }

    .nav-link:hover {
      color: #80a0ff;
    }

    .color-palette {
      margin: 0 auto;
      border: 2px solid #323437;
      background: #323437;
      display: inline-flex;
      gap: 0rem;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
    }

    .color-square {
      width: 5.15rem;
      height: 5.15em;
      border: 0px solid rgba(161, 205, 94, 0.3);
      position: relative;
      cursor: pointer;
    }

    .color-square::after {
      content: attr(data-color);
      position: absolute;
      bottom: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: #323437;
      border: 1px solid #80a0ff;
      color: #a1cd5e;
      padding: 4px 8px;
      font-size: 0.75rem;
      font-family: "Fira Code", monospace;
      opacity: 0;
      pointer-events: none;
      white-space: nowrap;
    }

    .color-square:hover::after {
      opacity: 1;
    }

    .fireflies {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .firefly {
      position: absolute;
      width: 4px;
      height: 4px;
      background: #a1cd5e;
      border-radius: 50%;
      box-shadow: 0 0 8px 2px #a1cd5e80;
    }

    .firefly:nth-child(1) { top: 10%; left: 15%; animation: firefly-drift-1 18s infinite ease-in-out, firefly-pulse-1 4s infinite ease-in-out; }
    .firefly:nth-child(2) { top: 25%; left: 80%; animation: firefly-drift-2 14s infinite ease-in-out, firefly-pulse-2 5s infinite ease-in-out; }
    .firefly:nth-child(3) { top: 60%; left: 10%; animation: firefly-drift-3 20s infinite ease-in-out, firefly-pulse-3 3s infinite ease-in-out; }
    .firefly:nth-child(4) { top: 80%; left: 70%; animation: firefly-drift-4 16s infinite ease-in-out, firefly-pulse-4 6s infinite ease-in-out; }
    .firefly:nth-child(5) { top: 40%; left: 85%; animation: firefly-drift-5 12s infinite ease-in-out, firefly-pulse-5 4s infinite ease-in-out; }
    .firefly:nth-child(6) { top: 15%; left: 50%; animation: firefly-drift-6 22s infinite ease-in-out, firefly-pulse-1 5s infinite ease-in-out; }
    .firefly:nth-child(7) { top: 70%; left: 30%; animation: firefly-drift-7 15s infinite ease-in-out, firefly-pulse-2 3s infinite ease-in-out; }
    .firefly:nth-child(8) { top: 35%; left: 20%; animation: firefly-drift-8 19s infinite ease-in-out, firefly-pulse-3 6s infinite ease-in-out; }
    .firefly:nth-child(9) { top: 55%; left: 75%; animation: firefly-drift-9 13s infinite ease-in-out, firefly-pulse-4 4s infinite ease-in-out; }
    .firefly:nth-child(10) { top: 90%; left: 45%; animation: firefly-drift-10 17s infinite ease-in-out, firefly-pulse-5 5s infinite ease-in-out; }

    @keyframes firefly-drift-1 {
      0%, 100% { transform: translate(0, 0); }
      25% { transform: translate(20px, -25px); }
      50% { transform: translate(-15px, 20px); }
      75% { transform: translate(25px, 5px); }
    }
    @keyframes firefly-drift-2 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(-25px, 15px); }
      66% { transform: translate(10px, -20px); }
    }
    @keyframes firefly-drift-3 {
      0%, 100% { transform: translate(0, 0); }
      20% { transform: translate(15px, 30px); }
      50% { transform: translate(-20px, -10px); }
      80% { transform: translate(30px, 15px); }
    }
    @keyframes firefly-drift-4 {
      0%, 100% { transform: translate(0, 0); }
      40% { transform: translate(-15px, -25px); }
      70% { transform: translate(20px, 10px); }
    }
    @keyframes firefly-drift-5 {
      0%, 100% { transform: translate(0, 0); }
      30% { transform: translate(25px, -15px); }
      60% { transform: translate(-10px, -25px); }
    }
    @keyframes firefly-drift-6 {
      0%, 100% { transform: translate(0, 0); }
      25% { transform: translate(-30px, 20px); }
      50% { transform: translate(15px, 25px); }
      75% { transform: translate(-20px, -15px); }
    }
    @keyframes firefly-drift-7 {
      0%, 100% { transform: translate(0, 0); }
      35% { transform: translate(20px, -30px); }
      65% { transform: translate(-25px, 10px); }
    }
    @keyframes firefly-drift-8 {
      0%, 100% { transform: translate(0, 0); }
      20% { transform: translate(-15px, 25px); }
      50% { transform: translate(30px, -20px); }
      80% { transform: translate(10px, 30px); }
    }
    @keyframes firefly-drift-9 {
      0%, 100% { transform: translate(0, 0); }
      40% { transform: translate(25px, 15px); }
      70% { transform: translate(-20px, -25px); }
    }
    @keyframes firefly-drift-10 {
      0%, 100% { transform: translate(0, 0); }
      30% { transform: translate(-10px, 30px); }
      60% { transform: translate(25px, 10px); }
      85% { transform: translate(-25px, -10px); }
    }

    @keyframes firefly-pulse-1 {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }
    @keyframes firefly-pulse-2 {
      0%, 100% { opacity: 0.3; }
      40% { opacity: 0.8; }
      70% { opacity: 0.5; }
    }
    @keyframes firefly-pulse-3 {
      0%, 100% { opacity: 0.5; }
      25% { opacity: 0.9; }
      75% { opacity: 0.6; }
    }
    @keyframes firefly-pulse-4 {
      0%, 100% { opacity: 0.35; }
      50% { opacity: 1; }
    }
    @keyframes firefly-pulse-5 {
      0%, 100% { opacity: 0.45; }
      30% { opacity: 0.85; }
      60% { opacity: 0.55; }
    }

    @media (max-width: 640px) {
      .center-box {
        min-width: unset;
        width: 100%;
        padding: 2rem;
      }
    }
  </style>
</Layout>
