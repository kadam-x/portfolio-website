  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    .hero {
      width: 100%;
      overflow: visible;
      line-height: 1.45;
      padding-left: 48px;
      padding-right: 48px;
    }

    .txt-row {
      white-space: nowrap;
      overflow: hidden;
      font-size: 11px;
      color: #cbcbcb;
      letter-spacing: 0.04em;
    }

    .middle-row {
      display: flex;
      width: 100%;
      gap: 6px;
    }

    .side-txt {
      display: flex;
      flex-direction: column;
      flex: 1;
      overflow: hidden;
      white-space: nowrap;
      font-size: 11px;
      color: #cbcbcb;
      letter-spacing: 0.04em;
      line-height: 1.45;
    }

    .side-txt.right {
      text-align: right;
    }

    .ascii-logo {
      font-size: 11.3px;
      line-height: 1.5;
      color: #cbcbcb;
      white-space: pre;
      flex: 1;
      overflow: visible;
    }

    :global(body) {
      background: #131313;
      color: #cbcbcb;
      font-family: "Courier New", Courier, monospace;
      font-size: 13px;
    }

    main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 220px 0 110px;
      gap: 16px;
      max-width: 700px;
      margin: 0 auto;
    }

    /* ‚ĒÄ‚ĒÄ nav ‚ĒÄ‚ĒÄ */
    nav {
      display: flex;
      gap: 14px;
      align-items: center;
      font-size: 14px;
      color: #cbcbcb;
    }

    nav a {
      color: #cbcbcb;
      font-weight: 700;
      text-decoration: underline;
    }

    nav a:hover {
      color: #cbcbcb;
    }

    .sep {
      color: #cbcbcb;
    }

    /* ‚ĒÄ‚ĒÄ contact ‚ĒÄ‚ĒÄ */
    .links {
      display: flex;
      flex-direction: column;
      gap: 5px;
      font-size: 13px;
      color: #cbcbcb;
      width: 100%;
      align-items: flex-start;
      padding-left: 45px;
    }

    .links a {
      color: #cbcbcb;
      font-weight: 700;
      text-decoration: underline;
    }

    .links a:hover {
      color: #cbcbcb;
    }

    .copy {
      color: #cbcbcb;
      font-weight: 700;
      text-decoration: underline;
      cursor: pointer;
    }

    .copy:hover {
      color: #cbcbcb;
    }

    #copy-hint {
      font-size: 11px;
      opacity: 0.35;
    }

    /* ‚ĒÄ‚ĒÄ quote ‚ĒÄ‚ĒÄ */
    .quote {
      font-size: 12px;
      color: #cbcbcb;
      line-height: 1.85;
      width: 100%;
      padding-left: 45px;
    }

    .quote .attr {
      margin-top: 4px;
      color: #cbcbcb;
    }

    .separator {
      font-size: 11px;
      color: #cbcbcb;
      letter-spacing: 0.04em;
      line-height: 1;
    }
  </style>

  <script>
    const emailBtn = document.getElementById("copy-email");
    const copyHint = document.getElementById("copy-hint");
    emailBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("kadamx@proton.me");
        if (copyHint) {
          copyHint.textContent = "(copied!)";
          setTimeout(() => {
            copyHint.textContent = "(click to copy)";
          }, 2000);
        }
      } catch (err) {
        console.error("Failed to copy:", err);
      }
    });
  </script>
</Layout>
