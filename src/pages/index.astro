---
import Layout from "../layouts/Layout.astro";
---

<Layout title="kovacsadam.dev" backgroundColor="#030210">
  <main class="hero-container">
    <div class="center-box">
      <div class="menu-box" id="welcome-header">
        <div class="menu-header">[*] INDEX</div>
        <h1 class="site-title">kovacsadam.dev</h1>
        <nav class="nav-links">
          <a href="/about" class="nav-link">&gt; about</a>
          <a href="/projects" class="nav-link">&gt; my projects</a>
          <a href="/contact" class="nav-link">&gt; contact me</a>
        </nav>
      </div>
    </div>
  </main>

  

  <style>
    .hero-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
      z-index: 1;
    }

    .center-box {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      position: relative;
    }

    .menu-box {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
      background: #d8d9ed;
      border: 1px solid #000000;
      border-top: 2px solid #000000;
      padding-bottom: 1rem;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 16px;
      min-width: 500px;
    }

    .menu-header {
      background: #cde6a8;
      color: #0c0e14;
      padding: 0.5rem 1rem;
      width: 100%;
      border-bottom: 1px solid #000000;
      font-size: 14px;
      text-align: left;
    }

    .site-title {
      font-size: 1.4rem;
      color: #000000;
      margin: 0;
      padding: 0 1rem;
    }

    .nav-links {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 0 1rem 2rem;
      width: 100%;
    }

    .nav-link {
      color: #0000FF;
      text-decoration: underline;
      padding: 0.25rem 0.5rem;
      display: inline-block;
      font-size: 16px;
    }

    .nav-link:hover {
      background: transparent;
      color: #ff0000;
    }

    @media (max-width: 640px) {
      .center-box {
        min-width: unset;
        width: 100%;
        padding: 2rem;
      }
    }
  </style>
</Layout>
