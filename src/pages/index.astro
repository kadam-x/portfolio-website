---
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>kovacsadam.dev</title>
</head>
<body>

  <main>
    <h1>KOVACS ADAM</h1>

    <img src="/small-adam.webp" alt="Kovacs Adam" />

    <p class="placeholder">
      Hey! Check out my <a href="/about">about</a> and <a href="/projects">projects</a> pages.
    </p>

    <div class="links">
      <p>Contact: <span id="copy-email" class="copy">kadamx [at] proton [dot] me</span> <span id="copy-hint">(click to copy)</span></p>
      <p>GitHub: <a href="https://github.com/kadam-x" target="_blank">@kadam-x</a></p>
      <p>LinkedIn: <a href="https://www.linkedin.com/in/kvcs-adam-s/" target="_blank">@Adam Kovacs</a></p>
      <p>Leetcode: <a href="https://leetcode.com/u/kadam-x/" target="_blank">@kadam-x</a></p>
    </div>
  </main>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      min-height: 100%;
      background: #0a0a0a;
      color: #e0ddd5;
      font-family: monospace;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 60px 40px 60px;
      gap: 28px;
    }

    h1 {
      font-size: clamp(18px, 3vw, 28px);
      font-weight: 700;
      letter-spacing: 0.15em;
    }

    img {
      width: min(340px, 80vw);
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      background: #1a1a1a;
    }

    .placeholder {
      font-size: clamp(12px, 1.5vw, 14px);
      color: #e0ddd5;
      text-align: center;
    }

    .placeholder a {
      color: #00e5ff;
      text-decoration: underline;
    }

    .links {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      font-size: clamp(12px, 1.5vw, 14px);
      color: #e0ddd5;
      text-align: center;
    }

    .links a {
      color: #e0ddd5;
      text-decoration: underline;
    }

    .copy {
      cursor: pointer;
    }

    #copy-hint {
      font-size: 11px;
      opacity: 0.5;
    }
  </style>

  <script>
    const emailBtn = document.getElementById("copy-email");
    const copyHint = document.getElementById("copy-hint");

    emailBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("kadamx@proton.me");
        copyHint.textContent = "(copied!)";
        setTimeout(() => { copyHint.textContent = "(click to copy)"; }, 2000);
      } catch (err) {
        console.error("Failed to copy:", err);
      }
    });
  </script>

</body>
</html>
