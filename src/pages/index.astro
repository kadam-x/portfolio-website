---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio" backgroundColor="#412E20">
  <main class="hero-container">
    <div class="center-box">
      <div class="welcome-header">
        <span class="welcome-text">WELCOME</span>
      </div>
      
      <nav class="nav-links">
        <a href="/about" class="nav-link">about</a>
        <a href="/projects" class="nav-link">projects</a>
        <a href="/contact" class="nav-link">contact</a>
      </nav>
      
      <div class="color-palette">
        <div class="color-square" style="background-color: #FFE4AF;"></div>
        <div class="color-square" style="background-color: #DA9F5F;"></div>
        <div class="color-square" style="background-color: #B88C57;"></div>
        <div class="color-square" style="background-color: #7B4F2E;"></div>
        <div class="color-square" style="background-color: #412E20;"></div>
        <div class="color-square" style="background-color: #342331;"></div>
        <div class="color-square" style="background-color: #2B1B12;"></div>
        <div class="color-square" style="background-color: #D73F24;"></div>
        <div class="color-square" style="background-color: #BD3B1F;"></div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .hero-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .center-box {
    padding: 3rem;
    min-width: 400px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    position: relative;
  }

  .center-box::before {
    content: '[';
    position: absolute;
    left: 15px;
    top: 150px;
    height: 100%;
    font-size: 18rem;
    color: #FFE4AF;
    line-height: 1;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    font-weight: 300;
    display: flex;
    align-items: flex-start;
    transform-origin: top left;
    transform: scaleY(5);
    transform: scaleX(1);
  }

  .center-box::after {
    content: ']';
    position: absolute;
    right: 15px;
    top: 150px;
    height: 100%;
    font-size: 18rem;
    color: #FFE4AF;
    line-height: 1;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    font-weight: 300;
    display: flex;
    align-items: flex-start;
    transform-origin: top right;
    transform: scaleY(5);
    transform: scaleX(1);
  }

  .welcome-header {
    text-align: center;
    margin: 0 auto;
    margin-bottom: 1rem;
    border: 2px solid #DA9F5F;
    padding: 0.75rem 7.2rem;
    background: #412E20;
    display: inline-block;
  }

  .welcome-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: #FFE4AF;
    letter-spacing: 0.1em;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0;
  }

  .nav-link {
    font-size: 1.5rem;
    color: #FFE4AF;
    text-align: center;
    transition: all 0.2s;
    padding: 0.5rem;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
  }

  .nav-link:hover {
    color: #EC753A;
  }

  .color-palette {
    margin: 0 auto;
    border: 0px solid #DA9F5F;
    padding: 1rem 3.5rem;
    background: #412E20;
    display: inline-flex;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .color-square {
    width: 1.5rem;
    height: 1.5rem;
    border: 1px solid rgba(255, 228, 175, 0.3);
  }

  @media (max-width: 640px) {
    .center-box {
      min-width: unset;
      width: 100%;
      padding: 2rem;
    }
  }
</style>