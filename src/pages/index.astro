---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio" backgroundColor="#412E20">
  <main class="hero-container">
    <div class="center-box">
      <div class="welcome-header">
        <span class="welcome-text">WELCOME</span>
      </div>
      
      <nav class="nav-links">
        <a href="/about" class="nav-link">who am I</a>
        <a href="/projects" class="nav-link">my projects</a>
        <a href="/contact" class="nav-link">contact me</a>
      </nav>
      
      <div class="color-palette">
        <div class="color-square" style="background-color: #FFE4AF;"></div>
        <div class="color-square" style="background-color: #DA9F5F;"></div>
        <div class="color-square" style="background-color: #EC753A;"></div>
        <div class="color-square" style="background-color: #412E20;"></div>
        <div class="color-square" style="background-color: #342331;"></div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .hero-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .center-box {
    padding: 3rem;
    min-width: 400px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    position: relative;
  }

  .welcome-header {
    text-align: center;
    margin: 0 auto;
    margin-bottom: 0rem;
    border: 2px solid #DA9F5F;
    padding: 1.2rem 9.2rem;
    background: #412E20;
    display: inline-block;
  }

  .welcome-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: #FFE4AF;
    letter-spacing: 0.1em;
  }

.nav-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 4.9rem;
    margin: 0 auto;
    background: #412E20;
    border: 20px solid #FFE4AF; /* The full box */
    position: relative;        /* Keeps the "covers" attached to this box */
  }

  /* These are the "Erasers" that create the bracket look */
  .nav-links::before,
  .nav-links::after {
    content: "";
    position: absolute;
    left: 15%;            /* Adjust this to make brackets wider or thinner */
    right: 15%;           /* Adjust this to match the left value */
    background: #412E20;  /* Matches your background color exactly */
    height: 20px;          /* Matches your border thickness exactly */
  }

  /* Position the top eraser over the top border */
  .nav-links::before {
    top: -20px;
  }

  /* Position the bottom eraser over the bottom border */
  .nav-links::after {
    bottom: -20px;
  }

  .nav-link {
    font-size: 1.8rem;
    color: #FFE4AF;
    text-align: center;
    transition: all 0.2s;
    padding: 0.5rem;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    z-index: 1; /* Ensures text stays "above" the erasers if they overlap */
  }

  .nav-link:hover {
    color: #EC753A;
  }

  .color-palette {
    margin: 0 auto;
    border: 2px solid #DA9F5F;
    background: #412E20;
    display: inline-flex;
    gap: 0rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .color-square {
    width: 5.15rem;
    height: 5.15em;
    border: 0px solid rgba(255, 228, 175, 0.3);
  }

  @media (max-width: 640px) {
    .center-box {
      min-width: unset;
      width: 100%;
      padding: 2rem;
    }
  }
</style>
