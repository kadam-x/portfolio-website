---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kovacs Adam :: Portfolio" backgroundColor="#030210">
  <main class="hero-container">
    <div class="center-box">
      <div class="welcome-header">
        <span class="welcome-text">WELCOME</span>
      </div>

      <nav class="nav-links">
        <a href="/about" class="nav-link">who am I</a>
        <a href="/projects" class="nav-link">my projects</a>
        <a href="/contact" class="nav-link">contact me</a>
      </nav>

      <div class="color-palette">
        <div
          class="color-square"
          data-color="#030210"
          style="background-color: #030210;"
        >
        </div>
        <div
          class="color-square"
          data-color="#323437"
          style="background-color: #323437;"
        >
        </div>
        <div
          class="color-square"
          data-color="#ff5454"
          style="background-color: #ff5454;"
        >
        </div>
        <div
          class="color-square"
          data-color="#80a0ff"
          style="background-color: #80a0ff;"
        >
        </div>
        <div
          class="color-square"
          data-color="#a1cd5e"
          style="background-color: #a1cd5e;"
        >
        </div>
      </div>
    </div>
  </main>

  <style>
    .hero-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .center-box {
      padding: 3rem;
      min-width: 400px;
      display: flex;
      flex-direction: column;
      gap: 3rem;
      position: relative;
    }

    .welcome-header {
      text-align: center;
      margin: 0 auto;
      margin-bottom: 0rem;
      border: 2px solid #323437;
      padding: 1.2rem 9.2rem;
      background: #030210;
      display: inline-block;
    }

    .welcome-text {
      font-size: 1.5rem;
      font-weight: 700;
      color: #80a0ff;
      letter-spacing: 0.1em;
    }

    .nav-links {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem 4.9rem;
      margin: 0 auto;
      background: #030210;
      border: 20px solid #a1cd5e;
      position: relative;
    }

    .nav-links::before,
    .nav-links::after {
      content: "";
      position: absolute;
      left: 15%;
      right: 15%;
      background: #030210;
      height: 20px;
    }

    /* Position the top eraser over the top border */
    .nav-links::before {
      top: -20px;
    }

    /* Position the bottom eraser over the bottom border */
    .nav-links::after {
      bottom: -20px;
    }

    .nav-link {
      font-size: 1.8rem;
      color: #a1cd5e;
      text-align: center;
      transition: all 0.2s;
      padding: 0.5rem;
      font-family: "Fira Code", "FiraCode Nerd Font", monospace;
      z-index: 1;
    }

    .nav-link:hover {
      color: #80a0ff;
    }

    .color-palette {
      margin: 0 auto;
      border: 2px solid #323437;
      background: #323437;
      display: inline-flex;
      gap: 0rem;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
    }

    .color-square {
      width: 5.15rem;
      height: 5.15em;
      border: 0px solid rgba(161, 205, 94, 0.3);
      position: relative;
      cursor: pointer;
    }

    .color-square::after {
      content: attr(data-color);
      position: absolute;
      bottom: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: #323437;
      border: 1px solid #80a0ff;
      color: #a1cd5e;
      padding: 4px 8px;
      font-size: 0.75rem;
      font-family: "Fira Code", monospace;
      opacity: 0;
      pointer-events: none;
      white-space: nowrap;
    }

    .color-square:hover::after {
      opacity: 1;
    }

    @media (max-width: 640px) {
      .center-box {
        min-width: unset;
        width: 100%;
        padding: 2rem;
      }
    }
  </style>
</Layout>
