---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kovacs Adam :: Portfolio" backgroundColor="#0f0f0d">
  <main class="hero-container">
    <div class="center-box">
      <div class="welcome-header">
        <span class="welcome-text">WELCOME</span>
      </div>

      <nav class="nav-links">
        <a href="/about" class="nav-link">who am I</a>
        <a href="/projects" class="nav-link">my projects</a>
        <a href="/contact" class="nav-link">contact me</a>
      </nav>

      <div class="color-palette">
        <div
          class="color-square"
          data-color="#0f0f0d"
          style="background-color: #0f0f0d;"
        >
        </div>
        <!-- Main background (Near black warm) -->
        <div
          class="color-square"
          data-color="#1d1c19"
          style="background-color: #1d1c19;"
        >
        </div>
        <!-- Surface / cards (Dark warm grey) -->
        <div
          class="color-square"
          data-color="#727169"
          style="background-color: #727169;"
        >
        </div>
        <!-- Muted / secondary text (Stone grey) -->
        <div
          class="color-square"
          data-color="#c5c9c5"
          style="background-color: #c5c9c5;"
        >
        </div>
        <!-- Primary text (Warm white) -->
        <div
          class="color-square"
          data-color="#9c8d7e"
          style="background-color: #9c8d7e;"
        >
        </div>
        <!-- Accent (Sediment) -->
      </div>
    </div>
  </main>

  <style>
    .hero-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .center-box {
      padding: 3rem;
      min-width: 400px;
      display: flex;
      flex-direction: column;
      gap: 3rem;
      position: relative;
    }

    .welcome-header {
      text-align: center;
      margin: 0 auto;
      margin-bottom: 0rem;
      /* border: 2px solid #da9f5f; */
      border: 2px solid #9c8d7e;
      padding: 1.2rem 9.2rem;
      /* background: #412e20; */
      /* background: #1d1c19; */
      background: #0f0f0d;
      display: inline-block;
    }

    .welcome-text {
      font-size: 1.5rem;
      font-weight: 700;
      /* color: #ffe4af; */
      color: #c5c9c5;
      letter-spacing: 0.1em;
    }

    .nav-links {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem 4.9rem;
      margin: 0 auto;
      /* background: #412e20; */
      /* background: #1d1c19; */
      background: #0f0f0d;
      /* border: 20px solid #ffe4af; */ /* The full box */
      border: 20px solid #c5c9c5; /* The full box */
      position: relative; /* Keeps the "covers" attached to this box */
    }

    /* These are the "Erasers" that create the bracket look */
    .nav-links::before,
    .nav-links::after {
      content: "";
      position: absolute;
      left: 15%; /* Adjust this to make brackets wider or thinner */
      right: 15%; /* Adjust this to match the left value */
      /* background: #412e20; */ /* Matches your background color exactly */
      background: #0f0f0d;
      height: 20px; /* Matches your border thickness exactly */
    }

    /* Position the top eraser over the top border */
    .nav-links::before {
      top: -20px;
    }

    /* Position the bottom eraser over the bottom border */
    .nav-links::after {
      bottom: -20px;
    }

    .nav-link {
      font-size: 1.8rem;
      /* color: #ffe4af; */
      color: #c5c9c5;
      text-align: center;
      transition: all 0.2s;
      padding: 0.5rem;
      font-family: "Fira Code", "FiraCode Nerd Font", monospace;
      z-index: 1; /* Ensures text stays "above" the erasers if they overlap */
    }

    .nav-link:hover {
      /* color: #ec753a; */
      color: #9c8d7e;
    }

    .color-palette {
      margin: 0 auto;
      /* border: 2px solid #da9f5f; */
      border: 2px solid #9c8d7e;
      /* background: #412e20; */
      background: #1d1c19;
      display: inline-flex;
      gap: 0rem;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
    }

    .color-square {
      width: 5.15rem;
      height: 5.15em;
      /* border: 0px solid rgba(255, 228, 175, 0.3); */
      border: 0px solid rgba(197, 201, 197, 0.3);
      position: relative;
      cursor: pointer;
    }

    .color-square::after {
      content: attr(data-color);
      position: absolute;
      bottom: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: #1d1c19;
      border: 1px solid #727169;
      color: #c5c9c5;
      padding: 4px 8px;
      font-size: 0.75rem;
      font-family: "Fira Code", monospace;
      opacity: 0;
      pointer-events: none;
      white-space: nowrap;
    }

    .color-square:hover::after {
      opacity: 1;
    }

    @media (max-width: 640px) {
      .center-box {
        min-width: unset;
        width: 100%;
        padding: 2rem;
      }
    }
  </style>
</Layout>
