---
// src/pages/projects/project-8.astro
import Layout from '../../layouts/Layout.astro';

const miniProjects = [
  {
    title: "Sales Data Analysis",
    description: "Analyzed retail sales data using Python and pandas to uncover trends in seasonality, customer behavior, and product performance. Identified top-performing cities, peak buying hours, and product bundling opportunities. Delivered actionable insights for marketing, pricing, and inventory pslanning.",
    link: "https://github.com/snezzz0/sales-data-analysis"
  },
  {
    title: "Arbitrage Bot",
    description: "A Bloomberg style crypto arbitrage bot using CoinGecko's API, Binance's API calculates spread and visualizes 24H data.",
    link: "https://github.com/snezzz0/crypto-arbitrage-test"
  },
  {
    title: "Churn Prediction",
    description: "End-to-end customer churn prediction pipeline using SQL Server, Python, and Power BI to flag at-risk customers. The project involved visualizing churn risk across different customer segments and recommending personalized retention offers, which enabled proactive, CRM-driven engagement and improved customer retention.",
    link: "https://github.com/snezzz0/churn-pred"
  },
  {
    title: "UI Component",
    description: "A standalone card component with hover effects.",
    link: "https://github.com/snezzz0/real-estate-ad-churn"
  }
];
---

<Layout title="Learning Projects" backgroundColor="#412E20">
  <main class="project-detail-container">
    <article class="project-detail" transition:name="project-8">
      <a href="/projects" class="back-link">
        <span class="arrow">←</span>
        <span>back to projects</span>
      </a>
      <div class="project-header">
        <h1>Learning Projects</h1>
        <span class="tag">Collection</span>
      </div>
      
      <p class="project-intro">
        A collection of smaller projects, experiments, and learning exercises.
      </p>

      <div class="mini-projects-grid">
        {miniProjects.map(project => (
          <div class="mini-project-card">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <a href={project.link}   
                target="_blank"
                rel="noopener noreferrer"class="mini-link">
              <span>View Project</span>
              <span class="arrow">→</span>
            </a>
          </div>
        ))}
      </div>
    </article>
  </main>
</Layout>

<style>
  .project-detail-container {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding: 4rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .back-link {
    position: absolute;
    top: -3rem;
    left: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #FFE4AF;
    font-size: 1rem;
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    transition: color 0.2s;
    z-index: 10;
    text-decoration: none;
  }

  .back-link:hover {
    color: #EC753A;
  }

  .arrow {
    font-size: 1.5rem;
  }

  .project-detail {
    background: #412E20;
    border: 3px solid #DA9F5F;
    padding: 2.5rem 2rem;
    max-width: 800px;
    width: 100%;
    margin-top: 3rem;
    position: relative;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .project-header h1 {
    font-size: 2rem;
    color: #FFE4AF;
    margin: 0;
  }

  .tag {
    background: #DA9F5F;
    color: #342331;
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
    border: 1px solid #EC753A;
    white-space: nowrap;
  }

  .project-intro {
    color: #DA9F5F;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* New styles for the mini projects grid */
  .mini-projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .mini-project-card {
    background: rgba(218, 159, 95, 0.05);
    border: 1px solid #DA9F5F;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.2s ease;
  }

  .mini-project-card:hover {
    border-color: #EC753A;
    background: rgba(218, 159, 95, 0.1);
  }

  .mini-project-card h3 {
    color: #FFE4AF;
    font-size: 1.25rem;
    margin: 0;
    font-family: 'Fira Code', monospace;
  }

  .mini-project-card p {
    color: #DA9F5F;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .mini-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #EC753A;
    text-decoration: none;
    font-family: 'Fira Code', monospace;
    font-size: 0.9rem;
    margin-top: auto;
    width: fit-content;
  }

  .mini-link:hover {
    color: #FFE4AF;
  }

  @media (max-width: 768px) {
    .project-detail-container {
      padding: 3rem 1rem 2rem;
    }

    .back-link {
      top: -2.5rem;
      font-size: 0.9rem;
    }

    .project-detail {
      padding: 2rem 1.5rem;
      margin-top: 2rem;
    }

    .project-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .project-header h1 {
      font-size: 1.5rem;
    }
    
    .mini-projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
