---
// src/pages/projects/project-5.astro
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Fifth Project" backgroundColor="#1d1c19">
  <main class="project-detail-container">
    <article class="project-detail" transition:name="project-5">
      <a href="/projects" class="back-link">
        <span class="arrow">←</span>
        <span>back to projects</span>
      </a>
      <div class="project-header">
        <h1>Fifth Project</h1>
        <span class="tag">Python</span>
      </div>

      <p class="project-intro">A data-focused project with Python.</p>

      <div class="project-content">
        <h2>Overview</h2>
        <p>
          This is a Python data analysis application that demonstrates data
          processing, machine learning, visualization, and statistical analysis
          capabilities.
        </p>

        <h2>Key Features</h2>
        <ul>
          <li>Data cleaning and preprocessing</li>
          <li>Statistical analysis and visualization</li>
          <li>Machine learning model training</li>
          <li>Interactive Jupyter notebooks</li>
          <li>Data export and reporting</li>
          <li>Automated data pipelines</li>
        </ul>

        <h2>Challenges & Solutions</h2>
        <p>
          One of the main challenges was processing large datasets efficiently.
          We solved this by using vectorized operations with NumPy and Pandas,
          and implementing chunked processing for memory efficiency.
        </p>

        <div class="project-links">
          <a href="#" class="project-link-btn primary">
            <span>Live Demo</span>
            <span class="arrow">→</span>
          </a>
          <a href="#" class="project-link-btn">
            <span>View Code</span>
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  .project-detail-container {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding: 4rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .back-link {
    position: absolute;
    top: -3rem;
    left: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #c5c9c5;
    font-size: 1rem;
    font-family: "Fira Code", "FiraCode Nerd Font", monospace;
    transition: color 0.2s;
    z-index: 10;
    text-decoration: none;
  }

  .back-link:hover {
    color: #9c8d7e;
  }

  .arrow {
    font-size: 1.5rem;
  }

  .project-detail {
    background: #1d1c19;
    border: 3px solid #c5c9c5;
    padding: 2.5rem 2rem;
    max-width: 800px;
    width: 100%;
    margin-top: 3rem;
    position: relative;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .project-header h1 {
    font-size: 2rem;
    color: #ffe4af;
    margin: 0;
  }

  .tag {
    background: #9c8d7e;
    color: #0f0f0d;
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
    border: 1px solid #9c8d7e;
    white-space: nowrap;
  }

  .project-intro {
    color: #9c8d7e;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .project-content h2 {
    color: #c5c9c5;
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .project-content p {
    color: #9c8d7e;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .project-content ul {
    color: #727169;
    line-height: 1.8;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .project-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #9c8d7e;
    border: 2px solid #9c8d7e;
    padding: 1rem 1.75rem;
    transition: all 0.2s;
    font-family: "Fira Code", "FiraCode Nerd Font", monospace;
    font-size: 1rem;
  }

  .project-link-btn.primary {
    background: #9c8d7e;
    color: #0f0f0d;
  }

  .project-link-btn:hover {
    background: #9c8d7e;
    color: #0f0f0d;
  }

  .project-link-btn.primary:hover {
    background: #9c8d7e;
    border-color: #9c8d7e;
  }

  .project-intro {
    color: #da9f5f;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .project-content h2 {
    color: #ffe4af;
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .project-content p {
    color: #da9f5f;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .project-tech span {
    background: rgba(218, 159, 95, 0.2);
    color: #da9f5f;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    border: 1px solid #da9f5f;
  }

  .project-content ul {
    color: #da9f5f;
    line-height: 1.8;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .project-content li {
    margin-bottom: 0.5rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .project-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #ec753a;
    border: 2px solid #ec753a;
    padding: 1rem 1.75rem;
    transition: all 0.2s;
    font-family: "Fira Code", "FiraCode Nerd Font", monospace;
    font-size: 1rem;
  }

  .project-link-btn.primary {
    background: #ec753a;
    color: #342331;
  }

  .project-link-btn:hover {
    background: #ec753a;
    color: #342331;
  }

  .project-link-btn.primary:hover {
    background: #da9f5f;
    border-color: #da9f5f;
  }

  @media (max-width: 768px) {
    .project-detail-container {
      padding: 3rem 1rem 2rem;
    }

    .back-link {
      top: -2.5rem;
      font-size: 0.9rem;
    }

    .project-detail {
      padding: 2rem 1.5rem;
      margin-top: 2rem;
    }

    .project-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .project-header h1 {
      font-size: 1.5rem;
    }

    .project-links {
      flex-direction: column;
    }

    .project-link-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
