---
// src/pages/projects/project-4.astro
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Fourth Project" backgroundColor="#1d1c19">
  <main class="project-detail-container">
    <article class="project-detail" transition:name="project-4">
      <a href="/projects" class="back-link">
        <span class="arrow">←</span>
        <span>back to projects</span>
      </a>
      <div class="project-header">
        <h1>Fourth Project</h1>
        <span class="tag">Node.js</span>
      </div>

      <p class="project-intro">
        A backend project showcasing server-side skills.
      </p>

      <div class="project-content">
        <h2>Overview</h2>
        <p>
          This is a Node.js backend application that demonstrates RESTful API
          design, database integration, authentication, and scalable
          architecture patterns.
        </p>

        <h2>Key Features</h2>
        <ul>
          <li>RESTful API with Express</li>
          <li>JWT-based authentication</li>
          <li>Real-time features with Socket.io</li>
          <li>MongoDB database integration</li>
          <li>Docker containerization</li>
          <li>Comprehensive error handling</li>
        </ul>

        <h2>Challenges & Solutions</h2>
        <p>
          One of the main challenges was implementing real-time features while
          maintaining server performance. We solved this by using Socket.io with
          Redis for horizontal scaling and optimizing database queries.
        </p>

        <div class="project-links">
          <a href="#" class="project-link-btn primary">
            <span>Live Demo</span>
            <span class="arrow">→</span>
          </a>
          <a href="#" class="project-link-btn">
            <span>View Code</span>
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  .project-detail-container {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding: 4rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .back-link {
    position: absolute;
    top: -3rem;
    left: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #c5c9c5;
    font-size: 1rem;
    font-family: "Fira Code", "FiraCode Nerd Font", monospace;
    transition: color 0.2s;
    z-index: 10;
    text-decoration: none;
  }

  .back-link:hover {
    color: #8ba4b0;
  }

  .arrow {
    font-size: 1.5rem;
  }

  .project-detail {
    background: #1d1c19;
    border: 3px solid #c5c9c5;
    padding: 2.5rem 2rem;
    max-width: 800px;
    width: 100%;
    margin-top: 3rem;
    position: relative;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .project-header h1 {
    font-size: 2rem;
    color: #c5c9c5;
    margin: 0;
  }

  .tag {
    background: #8ba4b0;
    color: #0f0f14;
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
    border: 1px solid #8ba4b0;
    white-space: nowrap;
  }

  .project-intro {
    color: #8ba4b0;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .project-content h2 {
    color: #c5c9c5;
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .project-content p {
    color: #8ba4b0;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .project-content ul {
    color: #727169;
    line-height: 1.8;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .project-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #8ba4b0;
    border: 2px solid #8ba4b0;
    padding: 1rem 1.75rem;
    transition: all 0.2s;
    font-family: "Fira Code", "FiraCode Nerd Font", monospace;
    font-size: 1rem;
  }

  .project-link-btn.primary {
    background: #8ba4b0;
    color: #0f0f14;
  }

  .project-link-btn:hover {
    background: #8ba4b0;
    color: #0f0f14;
  }

  .project-link-btn.primary:hover {
    background: #8ba4b0;
    border-color: #8ba4b0;
  }

  @media (max-width: 768px) {
    .project-detail-container {
      padding: 3rem 1rem 2rem;
    }

    .back-link {
      top: -2.5rem;
      font-size: 0.9rem;
    }

    .project-detail {
      padding: 2rem 1.5rem;
      margin-top: 2rem;
    }

    .project-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .project-header h1 {
      font-size: 1.5rem;
    }

    .project-links {
      flex-direction: column;
    }

    .project-link-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
