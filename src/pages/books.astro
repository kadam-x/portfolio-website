---
import Layout from "../layouts/Layout.astro";

const books = [
  { title: "The Intelligent Investor", author: "Benjamin Graham", status: "Completed", note: "The foundation of value investing." },
  { title: "A Philosophy of Software Design", author: "John Ousterhout", status: "Reading", note: "Essential for complexity management." },
  { title: "Antifragile", author: "Nassim Taleb", status: "Completed", note: "Probability and systems thinking." },
  { title: "Effective C++", author: "Scott Meyers", status: "Reading", note: "Deep dive into performance and control." },
];
---

<Layout title="Bookshelf" backgroundColor="#412E20">
  <main class="books-container" transition:animate="slide">
    <a href="/about" class="back-link">
      <span class="arrow">←</span>
      <span>back to about</span>
    </a>

    <header class="page-header">
      <h1>Library Log</h1>
      <p>A collection of papers and books that have shaped my thinking.</p>
    </header>

    <div class="log-table">
      <div class="table-header">
        <span class="col-title">Title</span>
        <span class="col-author">Author</span>
        <span class="col-status">Status</span>
      </div>

      {books.map((book) => (
        <div class="book-row">
          <div class="main-info">
            <span class="title">{book.title}</span>
            <span class="author">{book.author}</span>
            <span class={`status-tag ${book.status.toLowerCase()}`}>{book.status}</span>
          </div>
          {book.note && <p class="note">{book.note}</p>}
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .books-container {
    min-height: 100vh;
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
    font-family: "Fira Code", monospace;
    color: #FFE4AF; /* Cream text */
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #c5c9c5;
    font-size: 1rem;
    text-decoration: none;
    margin-bottom: 3rem;
    opacity: 0.7;
    transition: all 0.2s;
  }

  .back-link:hover {
    color: #9c8d7e;
    opacity: 1;
    transform: translateX(-4px);
  }

  .page-header h1 {
    font-size: 2.2rem;
    color: #FFE4AF;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: #FFE4AF;
    opacity: 0.8;
    margin-bottom: 4rem;
  }

  .table-header {
    display: grid;
    grid-template-columns: 2fr 1.2fr 100px;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 228, 175, 0.2);
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #ec753a;
    font-weight: bold;
  }

  .book-row {
    padding: 1.5rem 0;
    border-bottom: 1px dashed rgba(255, 228, 175, 0.1);
  }

  .main-info {
    display: grid;
    grid-template-columns: 2fr 1.2fr 100px;
    align-items: baseline;
    gap: 1rem;
  }

  .title {
    font-size: 1.1rem;
    color: #FFE4AF;
    font-weight: 600;
  }

  .author {
    font-size: 0.95rem;
    color: #FFE4AF;
    opacity: 0.8;
  }

  .status-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    border: 1px solid #FFE4AF;
    text-align: center;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .status-tag.reading {
    background: #ec753a;
    color: #412E20; /* Dark text on orange background */
    border-color: #ec753a;
  }

  .note {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    color: #FFE4AF;
    font-style: italic;
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .table-header { display: none; }
    .main-info { display: flex; flex-direction: column; gap: 0.5rem; }
  }
</style>
