---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kovacs Adam :: Theme" backgroundColor="var(--color-bg)">
  <main class="theme-container" id="page-wrapper">
    <div class="terminal-nav">
      <a href="/" class="back-link">
        <span class="arrow">←</span>
        <span>take me home</span>
      </a>
    </div>

    <div class="theme-box">
      <h1 class="theme-title">SELECT THEME</h1>
      <p class="theme-subtitle">Choose your palette</p>

      <div class="palettes">
<div class="palette-card" data-theme="sediment">
          <div class="palette-preview">
            <div class="preview-color" style="background: #23283d"></div>
            <div class="preview-color" style="background: #3d2a5e"></div>
            <div class="preview-color" style="background: #D4D4A0"></div>
            <div class="preview-color" style="background: #37f499"></div>
            <div class="preview-color" style="background: #987AFB"></div>
          </div>
          <div class="palette-info">
            <span class="palette-name">Neon</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>

        <div class="palette-card" data-theme="neon">
          <div class="palette-preview">
            <div class="preview-color" style="background: #23283d"></div>
            <div class="preview-color" style="background: #3d2a5e"></div>
            <div class="preview-color" style="background: #D4D4A0"></div>
            <div class="preview-color" style="background: #37f499"></div>
            <div class="preview-color" style="background: #987AFB"></div>
          </div>
          <div class="palette-info">
            <span class="palette-name">Neon</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>
<div class="palette-card" data-theme="sediment">
          <div class="palette-preview">
            <div class="preview-color" style="background: #030210"></div>
            <div class="preview-color" style="background: #0c0e14"></div>
            <div class="preview-color" style="background: #80a0ff"></div>
            <div class="preview-color" style="background: #a1cd5e"></div>
          </div>
          <div class="palette-info">
            <span class="palette-name">Moonfly</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>

          <div class="palette-info">
            <span class="palette-name">Neon</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>

        <div class="palette-card" data-theme="neon">
          <div class="palette-preview">
            <div class="preview-color" style="background: #23283d"></div>
            <div class="preview-color" style="background: #3d2a5e"></div>
            <div class="preview-color" style="background: #D4D4A0"></div>
            <div class="preview-color" style="background: #37f499"></div>
            <div class="preview-color" style="background: #987AFB"></div>
          </div>
          <div class="palette-info">
            <span class="palette-name">Neon</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>

        <div class="palette-card" data-theme="sediment">
          <div class="palette-preview">
            <div class="preview-color" style="background: #030210"></div>
            <div class="preview-color" style="background: #0c0e14"></div>
            <div class="preview-color" style="background: #80a0ff"></div>
            <div class="preview-color" style="background: #a1cd5e"></div>
          </div>
          <div class="palette-info">
            <span class="palette-name">Moonfly</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>
          <div class="palette-preview">
            <div class="preview-color" style="background: #0f0f0d"></div>
            <div class="preview-color" style="background: #1d1c19"></div>
            <div class="preview-color" style="background: #727169"></div>
            <div class="preview-color" style="background: #c5c9c5"></div>
            <div class="preview-color" style="background: #9c8d7e"></div>
          </div>
          <div class="palette-info">
            <span class="palette-name">Placeholder</span>
            <button class="apply-btn">Apply</button>
          </div>
        </div>
      </div>

      <div class="current-theme">
        <span class="current-label">Current:</span>
        <span id="current-theme-name">Neon</span>
      </div>
    </div>
  </main>
</Layout>

<script>
  const initThemePage = () => {
    const currentName = document.getElementById("current-theme-name");
    const cards = document.querySelectorAll(".palette-card");
    const saved = localStorage.getItem("site-theme") || "sediment";
    
    if (currentName) {
      const themes: Record<string, string> = {
        sediment: "Sediment",
        neon: "Neon",
        placeholder: "Placeholder"
      };
      currentName.textContent = themes[saved] || "Sediment";
    }

    cards.forEach((card) => {
      const btn = card.querySelector(".apply-btn");
      const themeName = card.getAttribute("data-theme");
      
      if (btn && themeName && window.__applyTheme) {
        btn.addEventListener("click", () => {
          (window as any).__applyTheme(themeName);
          if (currentName) {
            const themes: Record<string, string> = {
              sediment: "Sediment",
              neon: "Neon",
              placeholder: "Placeholder"
            };
            currentName.textContent = themes[themeName] || "Sediment";
          }
        });
      }
    });
  };

  initThemePage();
  document.addEventListener("astro:page-load", initThemePage);
</script>

<style>
  .theme-container {
    min-height: 100vh;
    padding: 4rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
    font-family: "Iosevka", monospace;
  }

  .terminal-nav {
    margin-bottom: 5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-secondary);
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .theme-box {
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    padding: 3rem;
  }

  .theme-title {
    color: var(--color-text);
    font-size: 2rem;
    margin: 0 0 0.5rem 0;
    letter-spacing: 0.1em;
  }

  .theme-subtitle {
    color: var(--color-secondary);
    font-size: 1rem;
    margin-bottom: 3rem;
  }

  .palettes {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .palette-card {
    background: var(--color-bg);
    border: 2px solid var(--color-secondary);
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .palette-card:hover {
    border-color: var(--color-accent);
    transform: translateX(10px);
  }

  .palette-preview {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .preview-color {
    width: 4rem;
    height: 2.5rem;
    border: 1px solid var(--color-secondary);
  }

  .palette-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .palette-name {
    color: var(--color-text);
    font-size: 1.2rem;
  }

  .apply-btn {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 0.5rem 1.5rem;
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .apply-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .current-theme {
    border-top: 1px solid var(--color-secondary);
    padding-top: 1.5rem;
    display: flex;
    gap: 0.5rem;
  }

  .current-label {
    color: var(--color-secondary);
  }

  #current-theme-name {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .theme-box {
      padding: 1.5rem;
    }
    .preview-color {
      width: 2.5rem;
      height: 2rem;
    }
  }
</style>