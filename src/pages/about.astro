---
import VintagePC from "../components/VintagePC.jsx";
const title = "Kovacs Adam :: About";
---

<!doctype html>
<html lang="en" style="width:100%;height:100%;margin:0;padding:0;">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        width: 100%;
        height: 100%;
        background: #000000;
        overflow: hidden;
      }
      astro-island {
        display: block;
        width: 100%;
        height: 100%;
      }
    </style>
  </head>
  <body>
    <VintagePC client:only="react" />
  </body>
</html>
