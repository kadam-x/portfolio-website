---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  backgroundColor?: string;
}

const { title, backgroundColor } = Astro.props;
---

<Layout title={title} backgroundColor={backgroundColor || "#030210"}>
  <main class="about-container">
    <a href="/" class="back-link">
      <span class="arrow">←</span>
      <span>take me home</span>
    </a>
    <div class="about-content">
      <slot />
    </div>
  </main>
</Layout>

<style is:global>
  .about-container {
    min-height: 100vh;
    padding: 4rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
    color: #a1cd5e;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #a1cd5e;
    text-decoration: none;
    font-size: 1rem;
    margin-bottom: 3rem;
    font-family: "Fira Code", monospace;
  }
  .back-link:hover {
    color: #a1cd5e;
  }
  .about-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .about-content h1 {
    font-size: 2.2rem;
    color: #a1cd5e;
    margin: 0 0 2rem 0;
    line-height: 1.3;
    text-align: center;
  }
  .about-content p {
    text-align: center;
    font-size: 1.15rem;
    line-height: 1.8;
    color: #a1cd5e;
    letter-spacing: 0.015em;
  }
  @media (max-width: 640px) {
    .about-container {
      padding: 2rem 1.5rem;
    }
    .about-content h1 {
      white-space: normal;
    }
  }
</style>