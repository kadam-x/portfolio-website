---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  backgroundColor?: string;
}

const { title, backgroundColor = '#FFE4AF' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <title>{title}</title>
  </head>
  <body style={`background-color: ${backgroundColor}`}>
    <slot />
    <script is:inline>
      // Add class for projects page swipe animation
      document.addEventListener('astro:before-preparation', (ev) => {
        const to = ev.to;
        if (to && (to.pathname === '/projects' || to.pathname === '/projects/')) {
          document.documentElement.classList.add('transitioning-to-projects');
        } else {
          document.documentElement.classList.remove('transitioning-to-projects');
        }
      });
      
      document.addEventListener('astro:after-swap', () => {
        if (window.location.pathname === '/projects' || window.location.pathname === '/projects/') {
          document.documentElement.classList.add('on-projects-page');
        } else {
          document.documentElement.classList.remove('on-projects-page');
        }
      });
      
      // Check on initial load
      if (window.location.pathname === '/projects' || window.location.pathname === '/projects/') {
        document.documentElement.classList.add('on-projects-page');
      }
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
    color: inherit;
  }
</style>