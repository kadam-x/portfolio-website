---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  backgroundColor?: string;
}

const { title, backgroundColor = "#030210" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="kovacsadam.dev" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.9"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#030210" />
    <meta name="theme-color" content="#030210" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/avatar/idle.png" as="image" />
    <link rel="preload" href="/avatar/eyes-closed.png" as="image" />
    <link rel="preload" href="/avatar/talking.png" as="image" />
    <!-- <link href="https://fonts.googleapis.com/css2?family=Iosevka:wght@400;500;600;700&display=swap" rel="stylesheet"> -->
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body style={`background-color: ${backgroundColor}`}>
    <div class="grain-overlay"></div>
    <slot />
    <script is:inline>
      // Navigation handling for View Transitions
      if (!window._transitionHandlersSet) {
        window._transitionHandlersSet = true;

        function getTransitionType(fromPath, toPath) {
          var from = fromPath.replace(/\/$/, "") || "/";
          var to = toPath.replace(/\/$/, "") || "/";

          var isProjectDetail = function (path) {
            return path.startsWith("/projects/project-");
          };

          var fromIsProject = isProjectDetail(from);
          var toIsProject = isProjectDetail(to);

          if (fromIsProject || toIsProject) {
            if (to === "/projects" && fromIsProject) return "fade";
            if (from === "/projects" && toIsProject) return "fade";
            if (fromIsProject && toIsProject) return "fade";
            if (toIsProject) return "fade";
            if (fromIsProject && to !== "/projects") return "fade";
          }

          if (to === "/" && from === "/about") return "back-top";
          if (to === "/" && from === "/contact") return "back-bottom";
          if (to === "/" && from === "/projects") return "back-right";
          if (to === "/" && from !== "/") return "back";
          if (to === "/about") return "slide-top";
          if (to === "/contact") return "slide-bottom";
          return "swipe";
        }

        document.addEventListener(
          "click",
          function (e) {
            var link = e.target.closest("a");
            if (!link || !link.href) return;

            try {
              var url = new URL(link.href, location.origin);
              if (url.origin !== location.origin) return;

              var type = getTransitionType(location.pathname, url.pathname);
              document.documentElement.setAttribute("data-transition", type);
            } catch (err) {}
          },
          true,
        );

        document.addEventListener("astro:before-preparation", function (e) {
          var type = getTransitionType(e.from.pathname, e.to.pathname);
          document.documentElement.setAttribute("data-transition", type);
        });

        document.addEventListener("astro:before-swap", function (e) {
          var type = document.documentElement.getAttribute("data-transition");
          if (type) {
            e.newDocument.documentElement.setAttribute("data-transition", type);
          }
        });

        document.addEventListener("astro:page-load", function () {
          setTimeout(function () {
            document.documentElement.removeAttribute("data-transition");
          }, 500);
        });
      }
    </script>

    <script is:inline>
      document.addEventListener('astro:page-load', function () {
        const fireflies = document.querySelectorAll('.firefly');
        fireflies.forEach(firefly => {
          firefly.style.display = 'none';
          firefly.offsetHeight;
          firefly.style.display = 'block';
        });
      });
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background-color: #030210;
  }

  body {
    font-family: "JetBrains Mono", monospace;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  .grain-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.5' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }
</style>
