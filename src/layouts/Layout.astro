---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="kovacsadam.dev" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.9"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#d8d9ed" />
    <meta name="theme-color" content="#d8d9ed" />
    <link rel="preload" href="/avatar/idle.png" as="image" />
    <link rel="preload" href="/avatar/eyes-closed.png" as="image" />
    <link rel="preload" href="/avatar/talking.png" as="image" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body style="background: #d8d9ed;">
    <div class="bg-layer"></div>
    <slot />
    <script is:inline>
      window.dispatchEvent(new Event('astro:page-load'));
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background-color: transparent;
  }

  body {
    font-family: monospace;
    overflow-x: hidden;
    min-height: 100vh;
    background: transparent;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: monospace;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  .bg-layer {
    position: fixed;
    inset: 0;
    height: 100vh;
    width: 100%;
    z-index: -1;
    background-image: url('/bg.webp');
    background-size: cover;
    background-position: center;
    filter: saturate(120%) contrast(115%) brightness(85%);
  }
</style>