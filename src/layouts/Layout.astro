---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  backgroundColor?: string;
}

const { title, backgroundColor = '#FFE4AF' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.9" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <title>{title}</title>
  </head>
  <body style={`background-color: ${backgroundColor}`}>
    <slot />
    <script is:inline>
      // Vanta.js initialization - must be in Layout to work with View Transitions
      // Use window to store state across View Transition navigations
      window._vantaState = window._vantaState || { effect: null, scriptsLoaded: false };

      function loadVantaScript(src) {
        return new Promise(function(resolve, reject) {
          // First check if global is already available
          if (src.includes('three') && typeof THREE !== 'undefined') {
            resolve();
            return;
          }
          if (src.includes('vanta') && typeof VANTA !== 'undefined') {
            resolve();
            return;
          }

          // Need to load the script
          var script = document.createElement('script');
          script.src = src;
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }

      function destroyVanta() {
        if (window._vantaState.effect) {
          try {
            window._vantaState.effect.destroy();
          } catch (e) {}
          window._vantaState.effect = null;
        }
      }

      function createVanta() {
        var el = document.getElementById('vanta-background');
        if (!el) return;
        if (typeof VANTA === 'undefined' || !VANTA.GLOBE) return;

        destroyVanta();

        try {
          window._vantaState.effect = VANTA.GLOBE({
            el: el,
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200.00,
            minWidth: 200.00,
            scale: 1.00,
            scaleMobile: 1.00,
            color: 0xec753a,
            color2: 0xffe4af,
            backgroundColor: 0x412e20
          });
        } catch (e) {
          console.error('Vanta init error:', e);
        }
      }

      function initVantaBackground() {
        var el = document.getElementById('vanta-background');
        if (!el) {
          destroyVanta();
          return;
        }

        // Check if scripts are actually loaded and functional (not just script tags present)
        var scriptsReady = typeof THREE !== 'undefined' && typeof VANTA !== 'undefined' && VANTA.GLOBE;
        
        if (scriptsReady) {
          createVanta();
          return;
        }

        // Scripts not ready - need to load them
        // First, remove any existing broken script tags
        var oldThree = document.querySelector('script[src*="three"]');
        var oldVanta = document.querySelector('script[src*="vanta"]');
        if (oldThree) oldThree.remove();
        if (oldVanta) oldVanta.remove();

        // Load fresh
        loadVantaScript('https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js')
          .then(function() {
            return loadVantaScript('/vanta.globe.min.js');
          })
          .then(function() {
            createVanta();
          })
          .catch(function(err) {
            console.error('Script load failed:', err);
          });
      }

      // Run on initial load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initVantaBackground);
      } else {
        initVantaBackground();
      }

      // Run after View Transition swap - use both events for reliability
      document.addEventListener('astro:after-swap', function() {
        // Small delay to ensure DOM is settled
        setTimeout(initVantaBackground, 50);
      });

      document.addEventListener('astro:page-load', function() {
        // Backup trigger with delay
        setTimeout(initVantaBackground, 100);
      });

      // Navigation handling for View Transitions
      if (!window._transitionHandlersSet) {
        window._transitionHandlersSet = true;

        function getTransitionType(fromPath, toPath) {
          var from = fromPath.replace(/\/$/, '') || '/';
          var to = toPath.replace(/\/$/, '') || '/';
          
          // Check if navigating to/from project detail pages
          var isProjectDetail = function(path) {
            return path.startsWith('/projects/project-');
          };
          
          var fromIsProject = isProjectDetail(from);
          var toIsProject = isProjectDetail(to);
          
          // Project detail pages - use fade transition (no swipe)
          if (fromIsProject || toIsProject) {
            // If going back to projects from a project detail, use fade
            if (to === '/projects' && fromIsProject) return 'fade';
            // If going from projects to project detail, use fade
            if (from === '/projects' && toIsProject) return 'fade';
            // If navigating between project details, use fade
            if (fromIsProject && toIsProject) return 'fade';
            // If coming from elsewhere to project detail, use fade
            if (toIsProject) return 'fade';
            // If going from project detail to elsewhere (except projects), use fade
            if (fromIsProject && to !== '/projects') return 'fade';
          }
          
          // Going home from about - slide back up (reverse of slide-top)
          if (to === '/' && from === '/about') return 'back-top';
          
          // Going home from contact - slide back down (reverse of slide-bottom)
          if (to === '/' && from === '/contact') return 'back-bottom';
          
          // Going home from projects - slide back right (reverse of swipe)
          if (to === '/' && from === '/projects') return 'back-right';
          
          // Going home from other pages
          if (to === '/' && from !== '/') return 'back';
          
          // About page - slide from top
          if (to === '/about') return 'slide-top';
          
          // Contact page - slide from bottom
          if (to === '/contact') return 'slide-bottom';
          
          // Default - swipe from right
          return 'swipe';
        }

        // Set on click - earliest possible moment
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a');
          if (!link || !link.href) return;
          
          try {
            var url = new URL(link.href, location.origin);
            if (url.origin !== location.origin) return;
            
            var type = getTransitionType(location.pathname, url.pathname);
            document.documentElement.setAttribute('data-transition', type);
            console.log('click: Set transition type:', type);
          } catch(err) {}
        }, true);

        // Also set in astro events as backup
        document.addEventListener('astro:before-preparation', function(e) {
          var type = getTransitionType(e.from.pathname, e.to.pathname);
          document.documentElement.setAttribute('data-transition', type);
          console.log('before-preparation: Set transition type:', type);
        });

        // Copy attribute to new document before swap
        document.addEventListener('astro:before-swap', function(e) {
          var type = document.documentElement.getAttribute('data-transition');
          if (type) {
            e.newDocument.documentElement.setAttribute('data-transition', type);
            console.log('before-swap: Copied transition type:', type);
          }
        });

        // Clear after transition completes
        document.addEventListener('astro:page-load', function() {
          setTimeout(function() {
            document.documentElement.removeAttribute('data-transition');
          }, 500);
        });
      }
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background-color: #412E20;
  }

  body {
    font-family: 'Fira Code', 'FiraCode Nerd Font', monospace;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
    color: inherit;
  }
</style>